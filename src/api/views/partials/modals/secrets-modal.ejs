<% if (!instance) { %>
    <% /* no modal if no instance */ %>
<% } else {
    const modalWalletAddress = instance.wallet_address || envWalletAddress || '';
    const modalPrivateKey    = instance.private_key    || envPrivateKey    || '';
%>
    <div class="modal fade" id="secretsModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Set secrets</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <div id="secretsResult" class="mb-3"></div>

                    <form
                            hx-put="/api/trade-instance/<%= instance.id %>/secrets"
                            hx-target="#secretsResult"
                            hx-swap="innerHTML"
                            hx-headers='{"Accept":"text/html"}'
                            hx-on::after-request="
              if (event.detail.successful) {
                setTimeout(() => {
                  const el = document.getElementById('secretsModal');
                  const modal = bootstrap.Modal.getInstance(el);
                  document.querySelector('#secretsModal input[name=private_key]').value = '';
                  modal?.hide();
                }, 2000);
              }
            "
                    >
                        <div class="mb-3">
                            <label class="form-label">Wallet address</label>
                            <input
                                    name="wallet_address"
                                    class="form-control"
                                    autocomplete="off"
                                    value="<%= modalWalletAddress %>"
                                    placeholder="0x..."
                            />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Private key</label>
                            <div class="input-group">
                                <input
                                        id="secretsPrivateKey"
                                        name="private_key"
                                        type="password"
                                        class="form-control"
                                        autocomplete="off"
                                        value="<%= modalPrivateKey %>"
                                        placeholder="Paste your private key"
                                />
                                <button
                                        type="button"
                                        class="btn btn-outline-secondary"
                                        onclick="
                                            const i = document.getElementById('secretsPrivateKey');
                                            const eye = this.querySelector('i');
                                            if (i.type === 'password') {
                                                i.type = 'text';
                                                eye.classList.replace('bi-eye', 'bi-eye-slash');
                                            } else {
                                                i.type = 'password';
                                                eye.classList.replace('bi-eye-slash', 'bi-eye');
                                            }
                                        "
                                        tabindex="-1"
                                >
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                                Cancel
                            </button>
                            <button type="submit" class="btn btn-primary">
                                Save
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
<% } %>
