<% if (!config) { %>
    <% /* no modal */ %>
<% } else { %>
    <div class="modal fade" id="configModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Grid Config</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <div id="configResult" class="mb-3"></div>

                    <form
                            id="tradeConfigForm"
                            hx-put="/api/trade-config/<%= config.id %>"
                            hx-swap="none"
                    >
                        <div class="row g-3">

                            <div class="col-12 col-md-3">
                                <label class="form-label">Token</label>
                                <input name="name" class="form-control" value="<%= config.name ?? '' %>" />
                            </div>

                            <div class="col-12 col-md-3">
                                <label class="form-label">Pair</label>
                                <input name="pair" class="form-control" value="<%= config.pair ?? '' %>" />
                            </div>

                            <div class="col-12 col-md-3">
                                <label class="form-label">Entry price</label>
                                <input name="entry_price" class="form-control" value="<%= config.entry_price ?? '' %>" />
                            </div>

                            <div class="col-12 col-md-3">
                                <label class="form-label">Exit price</label>
                                <input name="exit_price" class="form-control" value="<%= config.exit_price ?? '' %>" />
                            </div>

                            <div class="col-12 col-md-3">
                                <label class="form-label">Profit Target %</label>
                                <input name="target_percent" class="form-control" value="<%= config.target_percent ?? '' %>" />
                            </div>

                            <div class="col-12 col-md-3">
                                <label class="form-label">Grid distance % (each level)</label>
                                <input name="margin_percent" class="form-control" value="<%= config.margin_percent ?? '' %>" />
                            </div>

                            <div class="col-12 col-md-3">
                                <label class="form-label">USD per level $</label>
                                <input name="usd_transaction" class="form-control" value="<%= config.usd_transaction ?? '' %>" />
                            </div>

                            <div class="col-12 col-md-3">
                                <label class="form-label">Decimal quantity</label>
                                <input name="decimal_quantity" class="form-control" value="<%= config.decimal_quantity ?? '' %>" />
                            </div>

                            <div class="col-12 col-md-3">
                                <label class="form-label">Decimal price</label>
                                <input name="decimal_price" class="form-control" value="<%= config.decimal_price ?? '' %>" />
                            </div>

                            <div class="col-12 col-md-3">
                                <label class="form-label">Execution min</label>
                                <input name="execution_price_min" class="form-control" value="<%= config.execution_price_min ?? '' %>" />
                            </div>

                            <div class="col-12 col-md-3">
                                <label class="form-label">Execution max</label>
                                <input name="execution_price_max" class="form-control" value="<%= config.execution_price_max ?? '' %>" />
                            </div>

                            <div class="col-12 col-md-3">
                                <label class="form-label">Block USD at price</label>
                                <input name="order_block_price" class="form-control" value="<%= config.order_block_price ?? '' %>" />
                            </div>

                            <div class="col-12 mt-2">
                                <div class="border rounded p-3">
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <div class="fw-semibold">Rebuy</div>

                                        <div class="form-check m-0">
                                            <input
                                                    class="form-check-input"
                                                    type="checkbox"
                                                    id="rebuyProfit"
                                                    name="rebuy_profit"
                                                    <%= config.rebuy_profit ? 'checked' : '' %>
                                            />
                                            <label class="form-check-label" for="rebuyProfit">
                                                Rebuy profit
                                            </label>
                                        </div>
                                    </div>

                                    <div class="row g-3">
                                        <div class="col-12 col-md-3">
                                            <label class="form-label">Rebuy %</label>
                                            <input name="rebuy_percent" class="form-control" value="<%= config.rebuy_percent ?? '' %>" />
                                        </div>

                                        <div class="col-12 col-md-3">
                                            <label class="form-label">Rebuy value</label>
                                            <input
                                                    name="rebuy_value"
                                                    class="form-control"
                                                    value="<%= config.rebuy_value ?? '' %>"
                                                    disabled
                                            />
                                            <div class="form-text">Currently locked (read-only).</div>
                                        </div>

                                        <div class="col-12 col-md-3">
                                            <label class="form-label">Rebought value</label>
                                            <input class="form-control" value="<%= config.rebought_value ?? '' %>" disabled />
                                        </div>

                                        <div class="col-12 col-md-3">
                                            <label class="form-label">Rebought coin</label>
                                            <input class="form-control" value="<%= config.rebought_coin ?? '' %>" disabled />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-end gap-2 mt-4">
                                <button
                                        type="button"
                                        class="btn btn-outline-primary"
                                        data-grid-simulate="true"
                                        data-config-id="<%= config.id %>"
                                >
                                    Simulate grid
                                </button>

                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                                    Cancel
                                </button>
                                <button type="submit" class="btn btn-primary">
                                    Save
                                </button>
                            </div>

                            <div id="gridSimResult" class="mb-3"></div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
<% } %>

<script>
    function renderAlert(targetEl, type, message) {
        targetEl.innerHTML = `
      <div class="alert alert-${type} d-flex align-items-center gap-2 mb-0 py-2" role="alert">
        <span class="fw-semibold">${message}</span>
      </div>
    `;
    }

    document.body.addEventListener("htmx:afterRequest", (e) => {
        const form = e.target;
        if (!(form instanceof HTMLFormElement)) return;
        if (form.id !== "tradeConfigForm") return;

        const target = document.getElementById("configResult");
        if (!target) return;

        let payload = null;
        try {
            payload = JSON.parse(e.detail.xhr.responseText || "{}");
        } catch {
            renderAlert(target, "danger", "Unexpected response from server.");
            return;
        }

        if (e.detail.successful && payload && payload.success) {
            renderAlert(target, "success", "Config saved.");
            setTimeout(() => { target.innerHTML = ""; }, 2500);
        } else {
            const msg =
                payload?.message ||
                payload?.error ||
                "Could not save config. Please try again.";
            renderAlert(target, "danger", msg);
        }
    });
</script>