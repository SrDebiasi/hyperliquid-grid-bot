<% if (!config) { %>
    <% /* no modal */ %>
<% } else { %>
    <div class="modal fade" id="configModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Grid Range</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <div id="configResult" class="mb-3"></div>

                    <style>
                        .tip-label { cursor: help; }
                        .section-accent { border-left: 3px solid #dee2e6; padding-left: 0.65rem; }
                        .readonly-display {
                            background-color: #f8f9fa;
                            color: #6c757d;
                            font-family: monospace;
                            font-size: 0.8rem;
                            padding: 0.4rem 0.65rem;
                            border: 1px solid #dee2e6;
                            border-radius: 0.375rem;
                            min-height: 2.375rem;
                            overflow: hidden;
                            text-overflow: ellipsis;
                            white-space: nowrap;
                        }
                        .field-disabled { background-color: #f8f9fa !important; color: #6c757d !important; }
                    </style>

                    <form
                            id="tradeConfigForm"
                            hx-put="/api/trade-config/<%= config.id %>"
                            hx-swap="none"
                    >
                        <!-- Header -->
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <div class="fw-semibold">
                                <%= config.name ?? '-' %>
                                <span class="text-muted small ms-1">(<%= config.pair ?? '-' %>)</span>
                            </div>
                            <% if (config.trade_instance_id != null) { %>
                                <div class="text-muted small">Instance #<%= config.trade_instance_id %></div>
                            <% } %>
                        </div>

                        <!-- Row 1: Profit / Distance / Decimals -->
                        <div class="row g-3 align-items-end mb-2">
                            <div class="col-12 col-md-3">
                                <label class="form-label mb-1 tip-label d-flex align-items-center gap-1"
                                    data-bs-toggle="tooltip" data-bs-placement="top"
                                    title="Take profit for each completed buy → sell cycle. Example: 1.8 means +1.8% between buy and sell price."
                                >Target Profit % <i class="bi bi-question-circle text-muted" style="font-size:0.75rem;"></i></label>
                                <input name="target_percent" class="form-control" value="<%= config.target_percent ?? '' %>" />
                            </div>

                            <div class="col-12 col-md-3">
                                <label class="form-label mb-1 tip-label d-flex align-items-center gap-1"
                                    data-bs-toggle="tooltip" data-bs-placement="top"
                                    title="Distance between each grid level. Example: 0.1 means each level is 0.1% apart from the next."
                                >Distance Grid % <i class="bi bi-question-circle text-muted" style="font-size:0.75rem;"></i></label>
                                <input name="margin_percent" class="form-control" value="<%= config.margin_percent ?? '' %>" />
                            </div>

                            <div class="col-12 col-md-3">
                                <label class="form-label mb-1 tip-label d-flex align-items-center gap-1"
                                    data-bs-toggle="tooltip" data-bs-placement="top"
                                    title="Quantity precision for orders. e.g. 5 means the smallest order unit is 0.00001 BTC."
                                >Qty decimals <i class="bi bi-question-circle text-muted" style="font-size:0.75rem;"></i></label>
                                <input name="decimal_quantity" class="form-control" value="<%= config.decimal_quantity ?? '' %>" placeholder="e.g. 5" />
                            </div>

                            <div class="col-12 col-md-3">
                                <label class="form-label mb-1 tip-label d-flex align-items-center gap-1"
                                    data-bs-toggle="tooltip" data-bs-placement="top"
                                    title="Price precision for orders. e.g. 0 = whole numbers only, 2 = prices rounded to 0.01."
                                >Price decimals <i class="bi bi-question-circle text-muted" style="font-size:0.75rem;"></i></label>
                                <input name="decimal_price" class="form-control" value="<%= config.decimal_price ?? '' %>" placeholder="e.g. 0" />
                            </div>
                        </div>

                        <!-- Row 2: Execution Price Range -->
                        <div class="row g-3 align-items-end mb-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label mb-1 tip-label d-flex align-items-center gap-1"
                                    data-bs-toggle="tooltip" data-bs-placement="top"
                                    title="Optional price guardrails. BUY orders below min and SELL orders above max are skipped by the bot."
                                >Execution Price Range <i class="bi bi-question-circle text-muted" style="font-size:0.75rem;"></i></label>
                                <div class="input-group">
                                    <input name="execution_price_min" class="form-control" value="<%= config.execution_price_min ?? '' %>" placeholder="min" />
                                    <span class="input-group-text"><i class="bi bi-arrow-left-right"></i></span>
                                    <input name="execution_price_max" class="form-control" value="<%= config.execution_price_max ?? '' %>" placeholder="max" />
                                </div>
                            </div>
                        </div>

                        <!-- Reserves -->
                        <div class="col-12 mb-2">
                            <div class="border rounded p-3">
                                <div class="d-flex align-items-center justify-content-between mb-1">
                                    <div class="fw-semibold section-accent">Reserves</div>
                                    <div class="text-muted small">Locks balances using far-away limit orders</div>
                                </div>
                                <p class="text-muted small mb-3">
                                    <strong>USD (Quote)</strong> — places a <strong>BUY</strong> far below market to lock your USD balance. &nbsp;
                                    <strong>BTC (Base)</strong> — places a <strong>SELL</strong> far above market to lock your BTC balance.
                                </p>

                                <div class="row g-3 align-items-start">
                                    <div class="col-12 col-md-3">
                                        <label class="form-label mb-1 tip-label d-flex align-items-center gap-1"
                                            data-bs-toggle="tooltip" data-bs-placement="top"
                                            title="How far below market to place the USD reserve BUY order. Higher = further away, less likely to fill."
                                        >USD (Quote) offset <i class="bi bi-question-circle text-muted" style="font-size:0.75rem;"></i></label>
                                        <div class="input-group">
                                            <input name="reserve_quote_offset_percent" class="form-control" value="<%= config.reserve_quote_offset_percent ?? '' %>" placeholder="30" />
                                            <span class="input-group-text">%</span>
                                        </div>
                                    </div>

                                    <div class="col-12 col-md-3">
                                        <label class="form-label mb-1 text-muted small d-flex align-items-center gap-1"
                                            data-bs-toggle="tooltip" data-bs-placement="top"
                                            title="System-generated ID for the active USD reserve order. Managed automatically."
                                        >USD order ID <i class="bi bi-question-circle text-muted" style="font-size:0.75rem;"></i></label>
                                        <div class="readonly-display"><%= config.reserve_quote_order_id ?? '—' %></div>
                                        <input type="hidden" name="reserve_quote_order_id" value="<%= config.reserve_quote_order_id ?? '' %>" />
                                    </div>

                                    <div class="col-12 col-md-3">
                                        <label class="form-label mb-1 tip-label d-flex align-items-center gap-1"
                                            data-bs-toggle="tooltip" data-bs-placement="top"
                                            title="How far above market to place the BTC reserve SELL order. Higher = further away, less likely to fill."
                                        >BTC (Base) offset <i class="bi bi-question-circle text-muted" style="font-size:0.75rem;"></i></label>
                                        <div class="input-group">
                                            <input name="reserve_base_offset_percent" class="form-control" value="<%= config.reserve_base_offset_percent ?? '' %>" placeholder="30" />
                                            <span class="input-group-text">%</span>
                                        </div>
                                    </div>

                                    <div class="col-12 col-md-3">
                                        <label class="form-label mb-1 text-muted small d-flex align-items-center gap-1"
                                            data-bs-toggle="tooltip" data-bs-placement="top"
                                            title="System-generated ID for the active BTC reserve order. Managed automatically."
                                        >BTC order ID <i class="bi bi-question-circle text-muted" style="font-size:0.75rem;"></i></label>
                                        <div class="readonly-display"><%= config.reserve_base_order_id ?? '—' %></div>
                                        <input type="hidden" name="reserve_base_order_id" value="<%= config.reserve_base_order_id ?? '' %>" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Rebuy / Profit Reinvestment -->
                        <div class="col-12 mt-2">
                            <div class="border rounded p-3">
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <div class="fw-semibold section-accent tip-label"
                                        data-bs-toggle="tooltip" data-bs-placement="top"
                                        title="Accumulates a portion of each cycle's profit and uses it to buy more of the base token over time."
                                    >Profit Reinvestment</div>
                                    <div class="form-check form-switch m-0">
                                        <input
                                            class="form-check-input"
                                            type="checkbox"
                                            role="switch"
                                            id="rebuyProfit"
                                            name="rebuy_profit"
                                            <%= config.rebuy_profit ? 'checked' : '' %>
                                        />
                                        <label class="form-check-label tip-label" for="rebuyProfit"
                                            data-bs-toggle="tooltip" data-bs-placement="top"
                                            title="When enabled, a share of each completed cycle's profit is sent to the reinvestment wallet."
                                        >Enabled</label>
                                    </div>
                                </div>

                                <div class="row g-3">
                                    <div class="col-12 col-md-3">
                                        <label class="form-label tip-label d-flex align-items-center gap-1"
                                            data-bs-toggle="tooltip" data-bs-placement="top"
                                            title="Percentage of each cycle's profit that goes into the reinvestment wallet."
                                        >Profit allocation % <i class="bi bi-question-circle text-muted" style="font-size:0.75rem;"></i></label>
                                        <input name="rebuy_percent" class="form-control" value="<%= config.rebuy_percent ?? '' %>" />
                                    </div>

                                    <div class="col-12 col-md-3">
                                        <label class="form-label tip-label d-flex align-items-center gap-1"
                                            data-bs-toggle="tooltip" data-bs-placement="top"
                                            title="USD currently accumulated and waiting to be used for the next reinvestment purchase."
                                        >Pending rebuy (USD) <i class="bi bi-question-circle text-muted" style="font-size:0.75rem;"></i></label>
                                        <input name="rebuy_value" class="form-control field-disabled" value="<%= config.rebuy_value ?? '' %>" disabled />
                                    </div>

                                    <div class="col-12 col-md-3">
                                        <label class="form-label tip-label d-flex align-items-center gap-1"
                                            data-bs-toggle="tooltip" data-bs-placement="top"
                                            title="Total USD spent on reinvestment purchases so far."
                                        >Total spent (USD) <i class="bi bi-question-circle text-muted" style="font-size:0.75rem;"></i></label>
                                        <input class="form-control field-disabled" value="<%= config.rebought_value ?? '' %>" disabled />
                                    </div>

                                    <div class="col-12 col-md-3">
                                        <label class="form-label tip-label d-flex align-items-center gap-1"
                                            data-bs-toggle="tooltip" data-bs-placement="top"
                                            title="Total amount of the base token (e.g. BTC) acquired through reinvestment purchases."
                                        >Total coin acquired <i class="bi bi-question-circle text-muted" style="font-size:0.75rem;"></i></label>
                                        <input class="form-control field-disabled" value="<%= config.rebought_coin ?? '' %>" disabled />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="btn btn-outline-primary" data-grid-simulate="true" data-config-id="<%= config.id %>">
                                Simulate grid
                            </button>
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save</button>
                        </div>

                        <div id="gridSimResult" class="mb-3"></div>
                    </form>
                </div>
            </div>
        </div>
    </div>
<% } %>

<script>
    function renderAlert(targetEl, type, message) {
        targetEl.innerHTML = `
      <div class="alert alert-${type} d-flex align-items-center gap-2 mb-0 py-2" role="alert">
        <span class="fw-semibold">${message}</span>
      </div>
    `;
    }

    document.addEventListener('DOMContentLoaded', () => {
        const els = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        els.forEach((el) => new bootstrap.Tooltip(el));
    });

    document.body.addEventListener("htmx:afterRequest", (e) => {
        const form = e.target;
        if (!(form instanceof HTMLFormElement)) return;
        if (form.id !== "tradeConfigForm") return;

        const target = document.getElementById("configResult");
        if (!target) return;

        let payload = null;
        try {
            payload = JSON.parse(e.detail.xhr.responseText || "{}");
        } catch {
            renderAlert(target, "danger", "Unexpected response from server.");
            return;
        }

        if (e.detail.successful && payload && payload.success) {
            renderAlert(target, "success", "Config saved.");
            setTimeout(() => { target.innerHTML = ""; }, 2500);
        } else {
            const msg =
                payload?.message ||
                payload?.error ||
                "Could not save config. Please try again.";
            renderAlert(target, "danger", msg);
        }
    });

    function renderAlert(targetEl, type, message) {
        targetEl.innerHTML = `
      <div class="alert alert-${type} d-flex align-items-center gap-2 mb-0 py-2" role="alert">
        <span class="fw-semibold">${message}</span>
      </div>
    `;
    }

    document.addEventListener('DOMContentLoaded', () => {
        const els = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        els.forEach((el) => new bootstrap.Tooltip(el));

        const form = document.getElementById("tradeConfigForm");
        if (!form) return;

        const simBtn = form.querySelector('[data-grid-simulate="true"]');
        const saveBtn = form.querySelector('button[type="submit"]');
        const configTarget = document.getElementById("configResult");
        const simTarget = document.getElementById("gridSimResult");

        let baseline = null;
        let dirty = false;

        function stableSerializeForm(f) {
            const fd = new FormData(f);

            // ensure unchecked checkboxes are represented too (FormData omits them)
            f.querySelectorAll('input[type="checkbox"][name]').forEach((cb) => {
                if (!fd.has(cb.name)) fd.set(cb.name, "0");
            });

            const pairs = [];
            for (const [k, v] of fd.entries()) {
                pairs.push([k, String(v)]);
            }
            pairs.sort((a, b) => (a[0] + "=" + a[1]).localeCompare(b[0] + "=" + b[1]));
            return pairs.map(([k, v]) => `${encodeURIComponent(k)}=${encodeURIComponent(v)}`).join("&");
        }

        function setDirty(nextDirty) {
            dirty = nextDirty;

            if (simBtn) simBtn.disabled = dirty;

            // optional: small hint while dirty
            if (dirty && configTarget) {
                renderAlert(configTarget, "warning", "You have unsaved changes. Please save before simulating.");
            } else if (!dirty && configTarget) {
                // don’t clear a success message immediately; just leave as-is
                // (you already clear success after 2.5s)
            }
        }

        function refreshBaseline() {
            baseline = stableSerializeForm(form);
            setDirty(false);
        }

        function checkDirty() {
            if (baseline == null) {
                baseline = stableSerializeForm(form);
                return;
            }
            const now = stableSerializeForm(form);
            setDirty(now !== baseline);
        }

        // Mark dirty on any edit
        form.addEventListener("input", checkDirty, true);
        form.addEventListener("change", checkDirty, true);

        // When modal opens, reset baseline (so we compare from “current loaded values”)
        const modalEl = document.getElementById("configModal");
        if (modalEl) {
            modalEl.addEventListener("shown.bs.modal", () => {
                // clear simulate result when opening, optional
                if (simTarget) simTarget.innerHTML = "";
                refreshBaseline();
            });
        } else {
            // if modal event isn’t available for some reason, set baseline once on load
            refreshBaseline();
        }

        // Block simulate if dirty (extra guard even though we disable button)
        if (simBtn) {
            simBtn.addEventListener("click", (e) => {
                if (!dirty) return;

                e.preventDefault();
                e.stopPropagation();

                if (simTarget) {
                    renderAlert(simTarget, "warning", "Please save your changes before simulating.");
                } else if (configTarget) {
                    renderAlert(configTarget, "warning", "Please save your changes before simulating.");
                }

                // optional: nudge user to save
                if (saveBtn) saveBtn.focus();
            });
        }

        // expose helper for save handler below
        window.__tradeConfigDirty = {
            refreshBaseline,
            setDirty,
        };
    });

    document.body.addEventListener("htmx:afterRequest", (e) => {
        const form = e.target;
        if (!(form instanceof HTMLFormElement)) return;
        if (form.id !== "tradeConfigForm") return;

        const target = document.getElementById("configResult");
        if (!target) return;

        let payload = null;
        try {
            payload = JSON.parse(e.detail.xhr.responseText || "{}");
        } catch {
            renderAlert(target, "danger", "Unexpected response from server.");
            return;
        }

        if (e.detail.successful && payload && payload.success) {
            renderAlert(target, "success", "Config saved.");

            // IMPORTANT: after save, reset dirty + baseline
            if (window.__tradeConfigDirty?.refreshBaseline) {
                window.__tradeConfigDirty.refreshBaseline();
            }

            setTimeout(() => { target.innerHTML = ""; }, 2500);
        } else {
            const msg =
                payload?.message ||
                payload?.error ||
                "Could not save config. Please try again.";
            renderAlert(target, "danger", msg);
        }
    });
</script>