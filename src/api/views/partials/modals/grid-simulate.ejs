<div class="modal fade" id="simModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Grid Simulation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <p class="text-muted small mb-3">
                    Set a price range and order size — the bot will place buy/sell orders across that range, spaced by <strong>Distance Grid %</strong>, each targeting a profit of <strong>Target Profit %</strong>.
                </p>
                <div class="border rounded p-2 mb-3">
                    <div class="row g-2 align-items-end">
                        <div class="col-12 col-md-3">
                            <label for="simEntryPrice" class="form-label small mb-1">Entry Price</label>
                            <input
                                    type="number"
                                    class="form-control form-control-sm"
                                    id="simEntryPrice"
                                    min="0"
                                    step="any"
                                    placeholder="60000"
                                    value="60000"
                            >
                        </div>

                        <div class="col-12 col-md-3">
                            <label for="simExitPrice" class="form-label small mb-1">Exit Price</label>
                            <input
                                    type="number"
                                    class="form-control form-control-sm"
                                    id="simExitPrice"
                                    min="0"
                                    step="any"
                                    placeholder="100000"
                                    value="100000"
                            >
                        </div>

                        <div class="col-12 col-md-3">
                            <label for="simUsdTransaction" class="form-label small mb-1">USD per order</label>
                            <input
                                    type="number"
                                    class="form-control form-control-sm"
                                    id="simUsdTransaction"
                                    min="0"
                                    step="any"
                                    placeholder="20"
                                    value="20"
                            >
                        </div>

                        <div class="col-12 col-md-3 d-grid">
                            <button type="button" class="btn btn-primary btn-sm" id="simRunBtn">
                                Simulate
                            </button>
                        </div>
                    </div>
                </div>

                <div id="simError" class="mb-3"></div>
                <div id="simStatus" class="mb-3"></div>
                <div
                        id="simText"
                        class="small mb-0"
                        style="min-height: 320px;"
                ></div>
            </div>

            <div class="modal-footer d-flex justify-content-between">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Close
                </button>

                <button type="button" class="btn btn-success" id="simApproveBtn" disabled>
                    Agree & Generate grid
                </button>
            </div>
        </div>
    </div>
</div>