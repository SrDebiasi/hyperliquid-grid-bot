<!-- Manage Orders -->
<div class="modal fade" id="manageOrdersModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header py-2">
                <h5 class="modal-title flex items-center gap-2">
                    <i class="bi bi-list-ul text-secondary"></i>
                    Manage Orders
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">

                <!-- Stats cards -->
                <div class="grid grid-cols-1 md:grid-cols-4 gap-3 mb-3">

                    <div class="border border-border rounded-md p-3 h-full" style="border-left: 3px solid var(--muted-foreground);">
                        <div class="text-muted text-sm mb-1">Current price</div>
                        <div class="text-base font-semibold" id="moCurrentPrice">-</div>
                    </div>

                    <div class="border border-border rounded-md p-3 h-full" style="border-left: 3px solid var(--muted-foreground);">
                        <div class="text-muted text-sm mb-1">BTC needed</div>
                        <div class="font-semibold flex items-center gap-2 flex-wrap">
                            <span id="moBtcNeeded">-</span>
                            <span id="moBtcDelta" class="text-sm"></span>
                        </div>
                    </div>

                    <div class="border border-border rounded-md p-3 h-full" style="border-left: 3px solid var(--muted-foreground);">
                        <div class="text-muted text-sm mb-1">USD needed</div>
                        <div class="font-semibold flex items-center gap-2 flex-wrap">
                            <span id="moUsdNeeded">-</span>
                            <span id="moUsdDelta" class="text-sm"></span>
                        </div>
                    </div>

                    <div class="border border-border rounded-md p-3 h-full" style="border-left: 3px solid var(--muted-foreground);">
                        <div class="text-muted text-sm mb-1" id="moNetChangeLabel" style="display:none;">Change</div>
                        <div class="text-muted text-sm mb-1" id="moNetChangeLabelPlaceholder">Net change</div>
                        <div class="font-semibold">
                            <span id="moNetChange" class="text-sm"></span>
                        </div>
                    </div>

                </div>

                <!-- Controls bar -->
                <div class="border-t border-b py-2 my-2">
                    <div class="flex flex-wrap gap-3 items-center">

                        <!-- Select all -->
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="moSelectAll" checked>
                            <label class="form-check-label text-sm" for="moSelectAll">Select all</label>
                        </div>

                        <!-- Slider -->
                        <div class="flex items-center gap-2 grow" style="min-width: 180px;">
                            <span class="text-sm text-muted whitespace-nowrap">Order value (USD)</span>
                            <input
                                type="range"
                                class="form-range"
                                id="moValueSlider"
                                min="11"
                                max="500"
                                step="1"
                                value="100"
                                style="min-width: 80px;"
                            />
                            <span class="font-semibold text-sm whitespace-nowrap" id="moValueSliderLabel">$100</span>
                        </div>

                        <!-- Action buttons -->
                        <div class="flex gap-2 ml-auto">
                            <button class="btn btn-sm btn-outline-secondary" id="moRollbackBtn" type="button" disabled>
                                <i class="bi bi-arrow-counterclockwise mr-1"></i>Rollback
                            </button>
                            <button class="btn btn-sm btn-outline-danger" id="moDeleteBtn" type="button">
                                <i class="bi bi-trash mr-1"></i>Delete
                            </button>
                            <button class="btn btn-sm btn-success" id="moSaveBtn" type="button" disabled>
                                <i class="bi bi-check2 mr-1"></i>Save changes
                            </button>
                        </div>

                    </div>
                </div>

                <!-- Table -->
                <div class="table-responsive">
                    <table class="table table-sm mb-0" style="font-size: 0.85rem;">
                        <thead>
                        <tr>
                            <th style="width: 36px; font-size: 0.75rem; font-weight: 600; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--border);"></th>
                            <th class="text-right" style="font-size: 0.75rem; font-weight: 600; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--border)">Buy price</th>
                            <th class="text-right" style="font-size: 0.75rem; font-weight: 600; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--border)">Buy USD</th>
                            <th class="text-right" style="font-size: 0.75rem; font-weight: 600; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--border)">Sell price</th>
                            <th class="text-right" style="font-size: 0.75rem; font-weight: 600; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--border)">Sell USD</th>
                            <th class="text-right" style="font-size: 0.75rem; font-weight: 600; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--border);">Qty</th>
                            <th class="text-right" style="font-size: 0.75rem; font-weight: 600; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--border);">Entry price</th>
                        </tr>
                        </thead>
                        <tbody id="moTbody">
                        <tr><td colspan="7" class="text-muted">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>

                <div class="text-sm text-muted mt-2">
                    <i class="bi bi-info-circle mr-1"></i>Slider changes only update the local view until you click "Save changes".
                </div>

            </div>

            <div class="modal-footer py-2">
                <div class="mr-auto text-sm text-muted" id="moStatus"></div>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>

        </div>
    </div>
</div>

<!-- Extend Grid -->
<div class="modal fade" id="moExtendModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title flex items-center gap-2" id="moExtendModalTitle">
                    <i class="bi bi-plus-circle text-primary"></i> Add level
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">

                <!-- Preview -->
                <div class="border border-border rounded-md p-3 mb-3 text-sm">
                    <div class="text-muted mb-2">New order preview</div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-2 text-center">
                        <div>
                            <div class="text-muted text-sm">Buy price</div>
                            <div class="font-semibold" id="moExtendBuyPrice">—</div>
                        </div>
                        <div>
                            <div class="text-muted text-sm">Sell price</div>
                            <div class="font-semibold" id="moExtendSellPrice">—</div>
                        </div>
                        <div>
                            <div class="text-muted text-sm">Quantity</div>
                            <div class="font-semibold" id="moExtendQty">—</div>
                        </div>
                    </div>
                </div>

                <!-- Config params (read-only) -->
                <div class="flex gap-3 mb-3 text-sm text-muted">
                    <span><i class="bi bi-bullseye mr-1"></i>Target <span class="font-semibold text-body" id="moExtendTargetPct">—</span></span>
                    <span><i class="bi bi-arrows-collapse-vertical mr-1"></i>Grid distance <span class="font-semibold text-body" id="moExtendMarginPct">—</span></span>
                </div>

                <!-- Entry price -->
                <div class="mb-1">
                    <div class="font-semibold text-sm mb-2">Entry price</div>
                    <div class="flex flex-col gap-2">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="moExtendEntryType" id="moExtendEntrySame" value="same" checked>
                            <label class="form-check-label text-sm" for="moExtendEntrySame">
                                Same as adjacent order &mdash; <span class="font-semibold" id="moExtendEntrySameVal">—</span>
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="moExtendEntryType" id="moExtendEntryCurrent" value="current">
                            <label class="form-check-label text-sm" for="moExtendEntryCurrent">
                                Current market price &mdash; <span class="font-semibold" id="moExtendEntryCurrentVal">—</span>
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="moExtendEntryType" id="moExtendEntryCustom" value="custom">
                            <label class="form-check-label text-sm" for="moExtendEntryCustom">Custom</label>
                        </div>
                        <input type="number" class="form-control form-control-sm" id="moExtendEntryCustomInput"
                               placeholder="Enter price…" step="any" disabled>
                    </div>
                </div>

            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-primary" id="moExtendConfirmBtn">
                    <i class="bi bi-plus-circle mr-1"></i>Add level
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Confirm Save / Cancel on Exchange -->
<div class="modal fade" id="moConfirmSaveModal" tabindex="-1" aria-labelledby="moConfirmSaveModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title flex items-center gap-2" id="moConfirmSaveModalLabel">
                    <i class="bi bi-exclamation-triangle text-warning"></i>
                    Confirm save
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <div class="font-semibold mb-2">This will cancel orders on the exchange</div>
                <div class="text-muted text-sm">
                    If you proceed, <strong>ALL</strong> affected orders will be cancelled on Hyperliquid (buy and sell).
                    Then your new quantities will be saved.
                </div>
            </div>

            <div class="modal-footer py-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-success" id="moConfirmSaveProceedBtn">Yes, cancel &amp; save</button>
            </div>
        </div>
    </div>
</div>

<!-- Confirm Delete -->
<div class="modal fade" id="moConfirmDeleteModal" tabindex="-1" aria-labelledby="moConfirmDeleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title flex items-center gap-2" id="moConfirmDeleteModalLabel">
                    <i class="bi bi-trash text-danger"></i>
                    Delete orders
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <div class="font-semibold mb-2">This will cancel orders on the exchange</div>
                <div class="text-muted text-sm">
                    You are about to delete <strong><span id="moDeleteCount">0</span></strong> selected orders from the database.
                    If you proceed, their buy/sell orders will be cancelled on Hyperliquid (best effort) before deletion.
                </div>
            </div>

            <div class="modal-footer py-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-danger" id="moConfirmDeleteProceedBtn">Yes, cancel &amp; delete</button>
            </div>
        </div>
    </div>
</div>
