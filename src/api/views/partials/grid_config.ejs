<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h5 m-0">Grid Range</h2>

    <% if (config) { %>
        <div class="d-flex align-items-center gap-2">
            <% if (orders && orders.length > 0) { %>
                <button
                        type="button"
                        class="btn btn-outline-secondary btn-sm"
                        data-bs-toggle="modal"
                        data-bs-target="#manageOrdersModal"
                        data-trade-instance-id="<%= instance?.id %>"
                        data-pair="<%= config?.pair %>"
                >
                    <i class="bi bi-sliders me-1"></i>Manage Orders
                </button>
            <% } else { %>
                <button
                        type="button"
                        class="btn btn-outline-primary btn-sm"
                        data-grid-simulate="true"
                        data-config-id="<%= config.id %>"
                >
                    <i class="bi bi-play me-1"></i>Simulate Grid
                </button>
            <% } %>

            <button
                    type="button"
                    class="btn btn-outline-secondary btn-sm"
                    data-bs-toggle="modal"
                    data-bs-target="#configModal"
            >
                <i class="bi bi-pencil me-1"></i>Edit
            </button>
        </div>
    <% } %>
</div>

<% if (!instance) { %>
    <div class="alert alert-warning mb-0">No instance loaded.</div>

<% } else if (!config) { %>
    <div class="alert alert-warning mb-0">
        No config found for instance <%= instance.id %>.
    </div>

<% } else { %>
    <%
        const num = (v) => {
            const n = Number(v);
            return Number.isFinite(n) ? n : null;
        };

        const fmtPrice = (v) => {
            const n = num(v);
            return n === null ? '—' : n.toLocaleString('en-US', { maximumFractionDigits: 2 });
        };

        const fmtPct = (v) => {
            const n = num(v);
            return n === null ? '—' : n.toLocaleString('en-US', { maximumFractionDigits: 4 }) + '%';
        };

        const isBlank = (v) => v === null || v === undefined || v === '';
    %>

    <!-- Quick stats row -->
    <div class="row g-2 mb-3">
        <div class="col-12 col-md-4">
            <div class="border rounded p-2 h-100 profit-card profit-card-neutral">
                <div class="text-muted small mb-1">Spot pair</div>
                <div class="fw-semibold"><%= config.pair ?? '—' %></div>
            </div>
        </div>

        <div class="col-6 col-md-4">
            <div class="border rounded p-2 h-100 profit-card profit-card-neutral">
                <div class="text-muted small mb-1">Target profit</div>
                <div class="fw-semibold"><%= fmtPct(config.target_percent) %></div>
            </div>
        </div>

        <div class="col-6 col-md-4">
            <div class="border rounded p-2 h-100 profit-card profit-card-neutral">
                <div class="text-muted small mb-1">Grid distance</div>
                <div class="fw-semibold"><%= fmtPct(config.margin_percent) %></div>
            </div>
        </div>
    </div>

    <!-- Secondary info -->
    <div class="vstack gap-1 small">
        <div class="d-flex align-items-center gap-2">
            <% if (isBlank(config.execution_price_min) && isBlank(config.execution_price_max)) { %>
                <i class="bi bi-arrow-left-right text-muted" style="width:14px;"></i>
                <span class="text-muted">Execution range</span>
                <span class="text-muted ms-1" style="opacity:0.5;">(not set)</span>
            <% } else { %>
                <span class="fw-semibold"><%= fmtPrice(config.execution_price_min) %></span>
                <i class="bi bi-arrow-left-right text-muted"></i>
                <span class="fw-semibold"><%= fmtPrice(config.execution_price_max) %></span>
                <span class="text-muted">Execution range</span>
            <% } %>
        </div>

        <div class="d-flex align-items-center gap-2">
            <span class="text-muted">Decimals<% if (config.name) { %> · <%= config.name %><% } %></span>
            <span class="fw-semibold ms-1"><%= config.decimal_quantity ?? '—' %></span>
            <span class="text-muted">qty</span>
            <span class="text-muted">·</span>
            <span class="fw-semibold"><%= config.decimal_price ?? '—' %></span>
            <span class="text-muted">price</span>
        </div>
    </div>
<% } %>

<%- include('./modals/manage-orders-modal') %>
