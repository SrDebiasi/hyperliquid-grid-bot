<% if (profitSummary) { %>
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-end">
                <div>
                    <h2 class="h5 mb-1">Profits</h2>
                    <div class="text-muted small">
                        Daily chart: <%= profitSummary.dailyProfitMtd?.period?.label ?? '-' %>
                    </div>
                </div>
                <% if (rebuy) { %>
                    <div class="text-end small" style="line-height: 1.5;">
                        <div class="fw-semibold">Rebuy <%= rebuy.active ? 'Active' : 'Disabled' %></div>

                        <div class="text-muted">
                            Bought <%= Number(rebuy.reboughtCoin || 0).toFixed(5) %> <%= rebuy.name %> for <%= fmtUsd(rebuy.reboughtValueUsd) %>
                            → Now <%= fmtUsd(rebuy.currentValueUsd) %>
                        </div>

                        <div class="text-muted">
                            Avg. buy price <%= fmtUsd(rebuy.avgPriceUsd) %> →
                            <%= rebuy.name %> today: <%= fmtUsd(rebuy.currentPrice) %>
                        </div>
                    </div>
                <% } %>
            </div>

            <%
                function n(v, d = 0) {
                    return (typeof v === 'number' && Number.isFinite(v)) ? v : d;
                }

                function pct(v) {
                    return n(v, 0).toFixed(2);
                }

                function fmtUsd(x) {
                    return `$${n(Number(x), 0).toFixed(2)}`;
                }

                const emptyBucket = () => ({ pnlPercent: 0, totalUsd: 0, trades: 0 });

                const totals = profitSummary.totals || {};
                const t = {
                    today: totals.today || emptyBucket(),
                    week: totals.week || emptyBucket(),
                    month: totals.month || emptyBucket(),
                    year: totals.year || emptyBucket(),
                    allTime: totals.allTime || emptyBucket(),
                };
            %>

            <% if (portfolioOverview) { %>
                <div class="row g-3 mt-2 mb-3">
                    <div class="col-12 col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">Portfolio value at entry</div>
                            <div class="fs-5 fw-semibold"><%= fmtUsd(portfolioOverview.valueAtEntry) %></div>
                            <div class="text-muted small"> at average <%= portfolioOverview.symbol %> price of <%= fmtUsd(portfolioOverview.avgEntryPrice) %></div>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">Portfolio value at current price</div>
                            <div class="fs-5 fw-semibold mt-1"><%= fmtUsd(portfolioOverview.valueAtCurrent) %></div>
                            <div class="text-muted small"> at average <%= portfolioOverview.symbol %> price of <%= fmtUsd(portfolioOverview.currentPrice) %></div>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="text-muted small">Realized profit</div>
                                <div class="small fw-semibold text-success">
                                    +<%= pct(t.allTime.pnlPercent) %>%
                                </div>
                            </div>
                            <div class="fs-5 fw-semibold"><%= fmtUsd(portfolioOverview.realizedProfit) %></div>
                            <div class="text-muted small"><%= n(t.allTime.trades, 0) %> trades</div>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="text-muted small">Current portfolio</div>
                                <div class="small fw-semibold <%= portfolioOverview.portfolioDeltaPercent >= 0 ? 'text-success' : 'text-danger' %>">
                                    <%= portfolioOverview.portfolioDeltaPercent >= 0 ? '+' : '' %><%= pct(portfolioOverview.portfolioDeltaPercent) %>%
                                </div>
                            </div>
                            <div class="fs-5 fw-semibold"><%= fmtUsd(portfolioOverview.currentPortfolio) %></div>
                            <div class="text-muted mt-1" style="font-size: 0.8rem; line-height: 1.2;">
                                <%= portfolioOverview.portfolioDeltaUsd >= 0 ? '+' : '' %><%= fmtUsd(portfolioOverview.portfolioDeltaUsd) %> vs entry
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>

            <div class="row g-3 mt-2">
                <div class="col-12 col-md-4 col-xl">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="text-muted small">Today</div>
                            <div class="small fw-semibold text-success">
                                +<%= pct(t.today.pnlPercent) %>%
                            </div>
                        </div>
                        <div class="fs-5 fw-semibold"><%= fmtUsd(t.today.totalUsd) %></div>
                        <div class="text-muted small"><%= n(t.today.trades, 0) %> trades · <%= n(t.today.cycles, 0) %> cycles</div>
                    </div>
                </div>

                <div class="col-12 col-md-4 col-xl">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="text-muted small">Week</div>
                            <div class="small fw-semibold text-success">
                                +<%= pct(t.week.pnlPercent) %>%
                            </div>
                        </div>
                        <div class="fs-5 fw-semibold"><%= fmtUsd(t.week.totalUsd) %></div>
                        <div class="text-muted small"><%= n(t.week.trades, 0) %> trades · <%= n(t.week.cycles, 0) %> cycles</div>
                    </div>
                </div>

                <div class="col-12 col-md-4 col-xl">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="text-muted small">Month</div>
                            <div class="small fw-semibold text-success">
                                +<%= pct(t.month.pnlPercent) %>%
                            </div>
                        </div>
                        <div class="fs-5 fw-semibold"><%= fmtUsd(t.month.totalUsd) %></div>
                        <div class="text-muted small"><%= n(t.month.trades, 0) %> trades · <%= n(t.month.cycles, 0) %> cycles</div>
                    </div>
                </div>

                <div class="col-12 col-md-4 col-xl">
                    <div class="border rounded p-3 h-100">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="text-muted small">Year</div>
                            <div class="small fw-semibold text-success">
                                +<%= pct(t.year.pnlPercent) %>%
                            </div>
                        </div>
                        <div class="fs-5 fw-semibold"><%= fmtUsd(t.year.totalUsd) %></div>
                        <div class="text-muted small"><%= n(t.year.trades, 0) %> trades · <%= n(t.year.cycles, 0) %> cycles</div>
                    </div>
                </div>
            </div>

            <%
                const daily = profitSummary.dailyProfitMtd || {};
                const days = daily.days || [];
                const maxAbs = Math.max(1, ...days.map(d => Math.abs(Number(d.totalUsd || 0))));
            %>

            <hr class="my-4" />

            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="fw-semibold">Daily profit (MTD)</div>
                <div class="text-muted small">
                    Total: <%= fmtUsd(daily.totalUsd) %>
                    • Trades: <%= n(daily.trades, 0) %>
                    • Cycles: <%= n(daily.cycles, 0) %>
                </div>
            </div>

            <div class="small text-muted mb-2">Last <%= days.length %> days</div>

            <div class="vstack gap-0">
                <% days.forEach(d => {
                    const v = Number(d.totalUsd || 0);
                    const pctBar = Math.round((Math.abs(v) / maxAbs) * 100);
                    const isNeg = v < 0;
                %>
                <div class="d-flex align-items-center gap-0 small">
                    <div style="width:110px" class="text-muted"><%= d.date %></div>

                    <div class="progress flex-grow-1" style="height: 10px;">
                        <div
                                class="progress-bar <%= isNeg ? 'bg-danger' : 'bg-success' %>"
                                role="progressbar"
                                style="width: <%= pctBar %>%"
                                aria-valuenow="<%= pctBar %>"
                                aria-valuemin="0"
                                aria-valuemax="100">
                        </div>
                    </div>

                    <div style="width:120px" class="text-end fw-semibold">
                        <%= fmtUsd(v) %>
                    </div>
                    <div style="width:85px" class="text-end text-muted">
                        <%= n(d.trades, 0) %> trades
                    </div>
                    <div style="width:85px" class="text-end text-muted">
                        <%= n(d.cycles, 0) %> cycles
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </div>
<% } %>