<style>
@keyframes revealChart {
    from { clip-path: inset(0 100% 0 0); opacity: 0; }
    to   { clip-path: inset(0 0%   0 0); opacity: 1; }
}
.mtd-row { padding: 2px 4px; border-radius: 4px; transition: background 0.1s; }
.mtd-row:hover { background: var(--bs-secondary-bg); }
.mtd-row.zero { opacity: 0.38; }
.progress { border-radius: 6px !important; }
.progress-bar { border-radius: 6px !important; }
.profit-card { border-left: 3px solid #dee2e6; }
.profit-card-success { border-left-color: #198754 !important; }
.profit-card-danger  { border-left-color: #dc3545 !important; }
.profit-card-neutral { border-left-color: #adb5bd !important; }
.period-card { transition: box-shadow 0.15s; }
.period-card:hover { box-shadow: 0 0 0 1px var(--bs-border-color); }
</style>

<% if (profitSummary) { %>
    <div>

            <%
                function n(v, d = 0) {
                    return (typeof v === 'number' && Number.isFinite(v)) ? v : d;
                }
                function pct(v) { return n(v, 0).toFixed(2); }
                function fmtUsd(x) { return '$' + n(Number(x), 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
                function fmtDate(str) {
                    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
                    const p = String(str).split('-');
                    return p.length < 3 ? str : months[parseInt(p[1],10)-1] + ' ' + parseInt(p[2],10);
                }
                const emptyBucket = () => ({ pnlPercent: 0, totalUsd: 0, trades: 0, cycles: 0 });
                const totals = profitSummary.totals || {};
                const t = {
                    today:   totals.today   || emptyBucket(),
                    week:    totals.week    || emptyBucket(),
                    month:   totals.month   || emptyBucket(),
                    year:    totals.year    || emptyBucket(),
                    allTime: totals.allTime || emptyBucket(),
                };
            %>

            <!-- Header -->
            <div class="d-flex justify-content-between align-items-start mb-3">
                <h2 class="h5 mb-0">Profits</h2>
                <% if (rebuy) { %>
                    <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
                        <span class="badge <%= rebuy.active ? 'text-bg-success' : 'text-bg-secondary' %>">
                            Rebuy <%= rebuy.active ? 'Active' : 'Off' %>
                        </span>
                        <span class="text-muted small">
                            <%= Number(rebuy.reboughtCoin||0).toFixed(5) %> <%= rebuy.name %>
                            · paid <%= fmtUsd(rebuy.reboughtValueUsd) %> → worth <%= fmtUsd(rebuy.currentValueUsd) %>
                            · avg <%= fmtUsd(rebuy.avgPriceUsd) %> · price <%= fmtUsd(rebuy.currentPrice) %>
                        </span>
                    </div>
                <% } %>
            </div>

            <!-- Portfolio cards -->
            <% if (portfolioOverview) { %>
                <div class="row g-3 mb-4">
                    <div class="col-12 col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100 profit-card profit-card-neutral">
                            <div class="text-muted small mb-1">Entry value</div>
                            <div class="fs-5 fw-semibold"><%= fmtUsd(portfolioOverview.valueAtEntry) %></div>
                            <div class="text-muted small">avg <%= portfolioOverview.symbol %> <%= fmtUsd(portfolioOverview.avgEntryPrice) %></div>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-xl-3">
                        <% const currentDelta = portfolioOverview.valueAtCurrent - portfolioOverview.valueAtEntry; %>
                        <div class="border rounded p-3 h-100 profit-card <%= currentDelta >= 0 ? 'profit-card-success' : 'profit-card-danger' %>">
                            <div class="text-muted small mb-1">Current value</div>
                            <div class="fs-5 fw-semibold"><%= fmtUsd(portfolioOverview.valueAtCurrent) %></div>
                            <div class="text-muted small"><%= portfolioOverview.symbol %> today <%= fmtUsd(portfolioOverview.currentPrice) %></div>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100 profit-card profit-card-success">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <div class="text-muted small">Realized profit</div>
                                <div class="small fw-semibold text-success">+<%= pct(t.allTime.pnlPercent) %>%</div>
                            </div>
                            <div class="fs-5 fw-semibold text-success"><%= fmtUsd(portfolioOverview.realizedProfit) %></div>
                            <div class="text-muted small"><%= n(t.allTime.trades, 0).toLocaleString() %> trades</div>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-xl-3">
                        <% const isPos = portfolioOverview.portfolioDeltaPercent >= 0; %>
                        <div class="border rounded p-3 h-100 profit-card <%= isPos ? 'profit-card-success' : 'profit-card-danger' %>">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <div class="text-muted small">Portfolio today</div>
                                <div class="small fw-semibold <%= isPos ? 'text-success' : 'text-danger' %>">
                                    <%= isPos ? '+' : '' %><%= pct(portfolioOverview.portfolioDeltaPercent) %>%
                                </div>
                            </div>
                            <div class="fs-5 fw-semibold"><%= fmtUsd(portfolioOverview.currentPortfolio) %></div>
                            <div class="small <%= isPos ? 'text-success' : 'text-danger' %>">
                                <%= portfolioOverview.portfolioDeltaUsd >= 0 ? '+' : '' %><%= fmtUsd(portfolioOverview.portfolioDeltaUsd) %> vs entry
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>

            <%
                const daily      = profitSummary.dailyProfitMtd || {};
                const days       = daily.days || [];
                const maxAbs     = Math.max(1, ...days.map(d => Math.abs(Number(d.totalUsd || 0))));
                const allTimeDays = (profitSummary.allTimeDailyProfit || []).filter(d => d.totalUsd !== 0);

                // Estimates: actual period profit ÷ days elapsed × total period days
                const _today = new Date();

                // Week: days elapsed since Monday (Mon=1 … Sun=7)
                const _dayOfWeek = ((_today.getDay() + 6) % 7) + 1;
                const estWeek = _dayOfWeek > 0 ? (n(t.week.totalUsd, 0) / _dayOfWeek) * 7 : 0;

                // Month: days elapsed since day 1
                const mtdElapsed = days.length || 1;
                let totalDaysInMonth = 30;
                if (daily.period && daily.period.from) {
                    const p = String(daily.period.from).split('-');
                    if (p.length >= 2) totalDaysInMonth = new Date(parseInt(p[0],10), parseInt(p[1],10), 0).getDate();
                }
                const estMonth = (n(t.month.totalUsd, 0) / mtdElapsed) * totalDaysInMonth;

                // Year: days elapsed since Jan 1
                const _jan1 = new Date(_today.getFullYear(), 0, 1);
                const _daysElapsedYear = Math.floor((_today - _jan1) / 86400000) + 1;
                const _daysInYear = ((_today.getFullYear() % 4 === 0 && _today.getFullYear() % 100 !== 0) || _today.getFullYear() % 400 === 0) ? 366 : 365;
                const estYear = _daysElapsedYear > 0 ? (n(t.year.totalUsd, 0) / _daysElapsedYear) * _daysInYear : 0;
            %>

            <!-- Period widgets -->
            <div class="row g-3">
                <% [
                    { label: 'Today', data: t.today },
                    { label: 'Week',  data: t.week,  estimate: estWeek },
                    { label: 'Month', data: t.month, estimate: estMonth },
                    { label: 'Year',  data: t.year,  estimate: estYear },
                ].forEach(({ label, data, estimate }) => {
                    const isPos  = n(data.totalUsd, 0) > 0;
                    const isNeg  = n(data.totalUsd, 0) < 0;
                    const hasPct = n(data.pnlPercent, 0) !== 0;
                %>
                <div class="col-12 col-md-4 col-xl">
                    <div class="border rounded p-3 h-100 period-card profit-card <%= isPos ? 'profit-card-success' : isNeg ? 'profit-card-danger' : 'profit-card-neutral' %>">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="text-muted small"><%= label %></div>
                            <% if (hasPct) { %>
                                <div class="small fw-semibold <%= isPos ? 'text-success' : 'text-danger' %>">
                                    <%= isPos ? '+' : '' %><%= pct(data.pnlPercent) %>%
                                </div>
                            <% } %>
                        </div>
                        <div class="fs-5 fw-semibold <%= isPos ? 'text-success' : isNeg ? 'text-danger' : '' %>">
                            <%= fmtUsd(data.totalUsd) %>
                        </div>
                        <div class="d-flex justify-content-between align-items-end">
                            <div class="text-muted small"><%= n(data.trades,0) %> trades · <%= n(data.cycles,0) %> cycles</div>
                            <% if (estimate != null) { %>
                                <div class="text-muted small">est. <%= fmtUsd(estimate) %></div>
                            <% } %>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>

            <hr class="my-4" />

            <div class="row g-4">

                <!-- Left: MTD bar list -->
                <div class="col-12 col-lg-6">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="fw-semibold">Daily profit <span class="text-muted fw-normal small">(MTD)</span></div>
                        <div class="text-muted small">
                            <%= fmtUsd(daily.totalUsd) %> · <%= n(daily.trades,0) %> trades · <%= n(daily.cycles,0) %> cycles
                        </div>
                    </div>

                    <div class="vstack gap-0">
                        <% days.forEach(d => {
                            const v      = Number(d.totalUsd || 0);
                            const pctBar = Math.round((Math.abs(v) / maxAbs) * 100);
                            const isNeg  = v < 0;
                            const isZero = v === 0;
                        %>
                        <div class="d-flex align-items-center gap-0 small mtd-row <%= isZero ? 'zero' : '' %>">
                            <div style="width:52px" class="text-muted"><%= fmtDate(d.date) %></div>

                            <div class="progress flex-grow-1" style="height:8px; background:var(--bs-secondary-bg);">
                                <div class="progress-bar <%= isNeg ? 'bg-danger' : 'bg-success' %>"
                                     role="progressbar"
                                     style="width:<%= pctBar %>%">
                                </div>
                            </div>

                            <div style="width:90px" class="text-end fw-semibold <%= isNeg ? 'text-danger' : isZero ? 'text-muted' : 'text-success' %>">
                                <%= fmtUsd(v) %>
                            </div>
                            <div style="width:70px" class="text-end text-muted"><%= n(d.trades,0) %></div>
                            <div style="width:70px" class="text-end text-muted"><%= n(d.cycles,0) %></div>
                        </div>
                        <% }) %>
                    </div>
                </div>

                <!-- Right: all-time chart -->
                <div class="col-12 col-lg-6 d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="fw-semibold" id="allTimeChartTitle">Overtime profit <span class="text-muted fw-normal small">(all-time)</span></div>
                        <div class="d-flex align-items-center gap-2">
                            <div class="text-muted small"><%= allTimeDays.length %> days</div>
                            <div class="btn-group btn-group-sm" role="group" id="allTimeChartToggle">
                                <button type="button" class="btn btn-outline-secondary" data-chart-mode="daily">Daily</button>
                                <button type="button" class="btn btn-outline-secondary active" data-chart-mode="overtime">Overtime</button>
                            </div>
                        </div>
                    </div>
                    <div style="position:relative; width:100%; height:100%; min-height:200px;">
                        <canvas id="allTimeProfitChart" style="opacity:0;"></canvas>
                    </div>
                </div>

            </div>

            <script>
            setTimeout(function () {
                const canvas = document.getElementById('allTimeProfitChart');
                if (!canvas || typeof Chart === 'undefined') return;
                if (canvas._chartInstance) canvas._chartInstance.destroy();

                const raw    = <%- JSON.stringify(allTimeDays.map(d => ({ x: d.date, y: Number(d.totalUsd || 0) }))) %>;
                const labels = raw.map(d => d.x);
                const dailyValues = raw.map(d => d.y);

                // Cumulative sum for overtime view
                const overtimeValues = [];
                let running = 0;
                for (const v of dailyValues) { running += v; overtimeValues.push(running); }

                const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
                const gridColor = isDark ? 'rgba(255,255,255,0.08)' : '#f0f0f0';

                function makeGrad() {
                    const ctx = canvas.getContext('2d');
                    const grad = ctx.createLinearGradient(0, 0, 0, canvas.parentElement.clientHeight || 300);
                    grad.addColorStop(0, 'rgba(25,135,84,0.25)');
                    grad.addColorStop(1, 'rgba(25,135,84,0)');
                    return grad;
                }

                const titleLabels = {
                    daily:    'Daily profit <span class="text-muted fw-normal small">(all-time)</span>',
                    overtime: 'Overtime profit <span class="text-muted fw-normal small">(all-time)</span>',
                };

                const STORAGE_KEY = 'allTimeChartMode';
                const savedMode = localStorage.getItem(STORAGE_KEY) || 'overtime';
                const initData = savedMode === 'overtime' ? overtimeValues : dailyValues;

                canvas._chartInstance = new Chart(canvas, {
                    type: 'line',
                    data: {
                        labels,
                        datasets: [{
                            data: initData,
                            borderColor: '#198754',
                            borderWidth: 2,
                            tension: 0.4,
                            pointRadius: 0,
                            pointHoverRadius: 5,
                            pointHoverBackgroundColor: '#198754',
                            pointHoverBorderColor: '#fff',
                            pointHoverBorderWidth: 2,
                            fill: true,
                            backgroundColor: makeGrad(),
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: { duration: 0 },
                        interaction: { mode: 'index', intersect: false },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: '#212529',
                                titleColor: '#adb5bd',
                                bodyColor: '#fff',
                                padding: 10,
                                cornerRadius: 6,
                                callbacks: {
                                    title: (items) => labels[items[0]?.dataIndex] ?? '',
                                    label: (item)  => '  $' + Number(item.parsed.y).toFixed(2),
                                }
                            },
                        },
                        scales: {
                            x: { display: false },
                            y: {
                                grid: { color: gridColor },
                                border: { display: false },
                                ticks: {
                                    color: '#adb5bd',
                                    font: { size: 11 },
                                    callback: (v) => '$' + Number(v).toLocaleString('en-US', { maximumFractionDigits: 0 }),
                                },
                            },
                        },
                    }
                });

                canvas.style.animation = 'revealChart 2s cubic-bezier(0.16,1,0.3,1) forwards';

                // Apply saved mode to buttons + title on init
                const toggleGroup = document.getElementById('allTimeChartToggle');
                const titleEl = document.getElementById('allTimeChartTitle');
                function applyMode(mode) {
                    toggleGroup.querySelectorAll('button').forEach(b =>
                        b.classList.toggle('active', b.dataset.chartMode === mode)
                    );
                    if (titleEl) titleEl.innerHTML = titleLabels[mode] || titleLabels.overtime;
                    const chart = canvas._chartInstance;
                    if (!chart) return;
                    chart.data.datasets[0].data = mode === 'overtime' ? overtimeValues : dailyValues;
                    chart.data.datasets[0].backgroundColor = makeGrad();
                    chart.update('none');
                }

                applyMode(savedMode);

                if (toggleGroup) {
                    toggleGroup.addEventListener('click', function (e) {
                        const btn = e.target.closest('[data-chart-mode]');
                        if (!btn) return;
                        const mode = btn.dataset.chartMode;
                        localStorage.setItem(STORAGE_KEY, mode);
                        applyMode(mode);
                    });
                }
            }, 50);
            </script>
        </div>
<% } %>
