<style>
@keyframes revealChart {
    from { clip-path: inset(0 100% 0 0); opacity: 0; }
    to   { clip-path: inset(0 0%   0 0); opacity: 1; }
}
</style>

<% if (profitSummary) { %>
    <div>

            <%
                function n(v, d = 0) {
                    return (typeof v === 'number' && Number.isFinite(v)) ? v : d;
                }
                function pct(v) { return n(v, 0).toFixed(2); }
                function fmtUsd(x) { return '$' + n(Number(x), 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
                function badge(val, isUp) {
                    const color = isUp ? 'var(--primary)' : 'var(--destructive)';
                    const icon  = isUp ? 'bi-arrow-up-right' : 'bi-arrow-down-right';
                    const sign  = isUp ? '+' : '';
                    return `<span style="display:inline-flex;align-items:center;gap:3px;padding:2px 9px;border-radius:9999px;font-size:0.72rem;font-weight:600;background:color-mix(in oklch,${color} 14%,transparent);color:${color};"><i class="bi ${icon}" style="font-size:0.68rem;"></i>${sign}${val}</span>`;
                }
                function fmtDate(str) {
                    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
                    const p = String(str).split('-');
                    return p.length < 3 ? str : months[parseInt(p[1],10)-1] + ' ' + parseInt(p[2],10);
                }
                const emptyBucket = () => ({ pnlPercent: 0, totalUsd: 0, trades: 0, cycles: 0 });
                const totals = profitSummary.totals || {};
                const t = {
                    today:   totals.today   || emptyBucket(),
                    week:    totals.week    || emptyBucket(),
                    month:   totals.month   || emptyBucket(),
                    year:    totals.year    || emptyBucket(),
                    allTime: totals.allTime || emptyBucket(),
                };
            %>

            <!-- Header -->
            <div class="flex justify-between items-start mb-3">
                <h2 class="text-xl font-semibold mb-0">Profits</h2>
                <% if (rebuy) { %>
                    <div class="flex items-center gap-2 flex-wrap justify-end">
                        <span class="badge <%= rebuy.active ? 'text-bg-success' : 'text-bg-secondary' %>">
                            Rebuy <%= rebuy.active ? 'Active' : 'Off' %>
                        </span>
                        <span class="text-muted text-sm">
                            <%= Number(rebuy.reboughtCoin||0).toFixed(5) %> <%= rebuy.asset %>
                            · paid <%= fmtUsd(rebuy.reboughtValueUsd) %> → worth <%= fmtUsd(rebuy.currentValueUsd) %>
                            · avg <%= fmtUsd(rebuy.avgPriceUsd) %> · price <%= fmtUsd(rebuy.currentPrice) %>
                        </span>
                    </div>
                <% } %>
            </div>

            <!-- Portfolio cards -->
            <% if (portfolioOverview) { %>
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-3 mb-4">
                    <div class="border border-border rounded-md p-3 h-full" style="border-left: 3px solid var(--muted-foreground);">
                        <div class="text-muted text-sm mb-1">Entry value</div>
                        <div class="text-xl font-semibold mb-1"><%= fmtUsd(portfolioOverview.valueAtEntry) %></div>
                        <div class="text-muted text-sm">avg <%= portfolioOverview.symbol %> <%= fmtUsd(portfolioOverview.avgEntryPrice) %></div>
                    </div>

                    <%
                        const currentDelta = portfolioOverview.valueAtCurrent - portfolioOverview.valueAtEntry;
                        const currentIsPos = currentDelta >= 0;
                        const currentBorderColor = currentIsPos ? 'var(--primary)' : 'var(--destructive)';
                        const currentDeltaPct = portfolioOverview.valueAtEntry > 0 ? (currentDelta / portfolioOverview.valueAtEntry * 100) : 0;
                    %>
                    <div class="border border-border rounded-md p-3 h-full" style="border-left: 3px solid <%= currentBorderColor %>;">
                        <div class="flex justify-between items-start mb-1">
                            <div class="text-muted text-sm">Current value</div>
                            <%- badge(pct(currentDeltaPct) + '%', currentIsPos) %>
                        </div>
                        <div class="text-xl font-semibold mb-1"><%= fmtUsd(portfolioOverview.valueAtCurrent) %></div>
                        <div class="text-muted text-sm"><%= portfolioOverview.symbol %> today <%= fmtUsd(portfolioOverview.currentPrice) %></div>
                    </div>

                    <div class="border border-border rounded-md p-3 h-full" style="border-left: 3px solid var(--primary);">
                        <div class="flex justify-between items-start mb-1">
                            <div class="text-muted text-sm">Realized profit</div>
                            <%- badge(pct(t.allTime.pnlPercent) + '%', true) %>
                        </div>
                        <div class="text-xl font-semibold text-success mb-1"><%= fmtUsd(portfolioOverview.realizedProfit) %></div>
                        <div class="text-muted text-sm"><%= n(t.allTime.trades, 0).toLocaleString() %> trades</div>
                    </div>

                    <%
                        const isPos = portfolioOverview.portfolioDeltaPercent >= 0;
                        const portfolioBorderColor = isPos ? 'var(--primary)' : 'var(--destructive)';
                    %>
                    <div class="border border-border rounded-md p-3 h-full" style="border-left: 3px solid <%= portfolioBorderColor %>;">
                        <div class="flex justify-between items-start mb-1">
                            <div class="text-muted text-sm">Portfolio</div>
                            <%- badge(pct(portfolioOverview.portfolioDeltaPercent) + '%', isPos) %>
                        </div>
                        <div class="text-xl font-semibold mb-1"><%= fmtUsd(portfolioOverview.currentPortfolio) %></div>
                        <div class="text-sm <%= isPos ? 'text-success' : 'text-danger' %>">
                            <%= portfolioOverview.portfolioDeltaUsd >= 0 ? '+' : '' %><%= fmtUsd(portfolioOverview.portfolioDeltaUsd) %> vs entry
                        </div>
                    </div>
                </div>
            <% } %>

            <%
                const daily      = profitSummary.dailyProfitMtd || {};
                const days       = daily.days || [];
                const maxAbs     = Math.max(1, ...days.map(d => Math.abs(Number(d.totalUsd || 0))));
                const allTimeDays = (profitSummary.allTimeDailyProfit || []).filter(d => d.totalUsd !== 0);

                // Estimates: actual period profit ÷ days elapsed × total period days
                const _today = new Date();

                // Week: days elapsed since Monday (Mon=1 … Sun=7)
                const _dayOfWeek = ((_today.getDay() + 6) % 7) + 1;
                const estWeek = _dayOfWeek > 0 ? (n(t.week.totalUsd, 0) / _dayOfWeek) * 7 : 0;

                // Month: days elapsed since day 1
                const mtdElapsed = days.length || 1;
                let totalDaysInMonth = 30;
                if (daily.period && daily.period.from) {
                    const p = String(daily.period.from).split('-');
                    if (p.length >= 2) totalDaysInMonth = new Date(parseInt(p[0],10), parseInt(p[1],10), 0).getDate();
                }
                const estMonth = (n(t.month.totalUsd, 0) / mtdElapsed) * totalDaysInMonth;

                // Year: days elapsed since Jan 1
                const _jan1 = new Date(_today.getFullYear(), 0, 1);
                const _daysElapsedYear = Math.floor((_today - _jan1) / 86400000) + 1;
                const _daysInYear = ((_today.getFullYear() % 4 === 0 && _today.getFullYear() % 100 !== 0) || _today.getFullYear() % 400 === 0) ? 366 : 365;
                const estYear = _daysElapsedYear > 0 ? (n(t.year.totalUsd, 0) / _daysElapsedYear) * _daysInYear : 0;
            %>

            <!-- Period widgets -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
                <% [
                    { label: 'Today', data: t.today },
                    { label: 'Week',  data: t.week,  estimate: estWeek },
                    { label: 'Month', data: t.month, estimate: estMonth },
                    { label: 'Year',  data: t.year,  estimate: estYear },
                ].forEach(({ label, data, estimate }) => {
                    const isPos  = n(data.totalUsd, 0) > 0;
                    const isNeg  = n(data.totalUsd, 0) < 0;
                    const hasPct = n(data.pnlPercent, 0) !== 0;
                    const periodBorderColor = isPos ? 'var(--primary)' : isNeg ? 'var(--destructive)' : 'var(--muted-foreground)';
                %>
                <div class="border border-border rounded-md p-3 h-full" style="border-left: 3px solid <%= periodBorderColor %>; transition: box-shadow 0.15s;">
                    <div class="flex justify-between items-start mb-1">
                        <div class="text-muted text-sm"><%= label %></div>
                        <% if (hasPct) { %>
                            <%- badge(pct(data.pnlPercent) + '%', isPos) %>
                        <% } %>
                    </div>
                    <div class="text-xl font-semibold mb-1 <%= isPos ? 'text-success' : isNeg ? 'text-danger' : '' %>">
                        <%= fmtUsd(data.totalUsd) %>
                    </div>
                    <div class="flex justify-between items-end">
                        <div class="text-muted text-sm"><%= n(data.trades,0) %> trades · <%= n(data.cycles,0) %> cycles</div>
                        <% if (estimate != null) { %>
                            <div class="text-muted text-sm">est. <%= fmtUsd(estimate) %></div>
                        <% } %>
                    </div>
                </div>
                <% }) %>
            </div>

            <hr class="my-4" />

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">

                <!-- Left: MTD bar list -->
                <div>
                    <div class="flex justify-between items-center mb-3">
                        <div class="font-semibold">Daily profit <span class="text-muted font-normal text-sm">(MTD)</span></div>
                        <div class="text-muted text-sm">
                            <%= fmtUsd(daily.totalUsd) %> · <%= n(daily.trades,0) %> trades · <%= n(daily.cycles,0) %> cycles
                        </div>
                    </div>

                    <div class="flex flex-col gap-0">
                        <% days.forEach(d => {
                            const v      = Number(d.totalUsd || 0);
                            const pctBar = Math.round((Math.abs(v) / maxAbs) * 100);
                            const isNeg  = v < 0;
                            const isZero = v === 0;
                        %>
                        <div class="flex items-center gap-0 text-sm" style="padding: 1px 4px; border-radius: 4px; transition: background 0.1s;<%= isZero ? ' opacity: 0.38;' : '' %>" onmouseover="this.style.background='var(--muted)'" onmouseout="this.style.background=''">
                            <div style="width:52px; margin-right:3px;" class="text-muted whitespace-nowrap"><%= fmtDate(d.date) %></div>

                            <div class="progress grow" style="height:8px; background:var(--muted);">
                                <div class="progress-bar <%= isNeg ? 'bg-danger' : 'bg-success' %>"
                                     role="progressbar"
                                     style="width:<%= pctBar %>%">
                                </div>
                            </div>

                            <div style="width:90px" class="text-right font-semibold <%= isNeg ? 'text-danger' : isZero ? 'text-muted' : 'text-success' %>">
                                <%= fmtUsd(v) %>
                            </div>
                            <div style="width:70px" class="text-right text-muted"><%= n(d.trades,0) %></div>
                            <div style="width:70px" class="text-right text-muted"><%= n(d.cycles,0) %></div>
                        </div>
                        <% }) %>
                    </div>
                </div>

                <!-- Right: all-time chart -->
                <div class="flex flex-col">
                    <div class="flex justify-between items-center mb-3">
                        <div class="font-semibold" id="allTimeChartTitle">Overtime profit <span class="text-muted font-normal text-sm">(all-time)</span></div>
                        <div class="flex items-center gap-3">
                            <div class="text-muted text-sm"><%= allTimeDays.length %> days</div>
                            <div id="allTimeChartToggle" style="display:inline-flex; gap:4px; background:var(--muted); border-radius:9999px; padding:3px;">
                                <button type="button" data-chart-mode="daily"
                                    style="border:none; border-radius:9999px; padding:3px 14px; font-size:0.8rem; font-weight:500; cursor:pointer; transition:all 0.15s; background:transparent; color:var(--muted-foreground);">Daily</button>
                                <button type="button" data-chart-mode="overtime"
                                    style="border:none; border-radius:9999px; padding:3px 14px; font-size:0.8rem; font-weight:500; cursor:pointer; transition:all 0.15s; background:var(--card); color:var(--foreground); box-shadow:var(--shadow-sm);">Overtime</button>
                            </div>
                        </div>
                    </div>
                    <div style="position:relative; width:100%; height:100%; min-height:200px;">
                        <canvas id="allTimeProfitChart" style="opacity:0;"></canvas>
                    </div>
                </div>

            </div>

            <script>
            setTimeout(function () {
                const canvas = document.getElementById('allTimeProfitChart');
                if (!canvas || typeof Chart === 'undefined') return;
                if (canvas._chartInstance) canvas._chartInstance.destroy();

                const raw    = <%- JSON.stringify(allTimeDays.map(d => ({ x: d.date, y: Number(d.totalUsd || 0) }))) %>;
                const labels = raw.map(d => d.x);
                const dailyValues = raw.map(d => d.y);

                // Cumulative sum for overtime view
                const overtimeValues = [];
                let running = 0;
                for (const v of dailyValues) { running += v; overtimeValues.push(running); }

                const cs = getComputedStyle(document.documentElement);
                const primaryColor  = cs.getPropertyValue('--primary').trim();
                const mutedFgColor  = cs.getPropertyValue('--muted-foreground').trim();
                const borderColor   = cs.getPropertyValue('--border').trim();
                const cardBgColor   = cs.getPropertyValue('--card').trim();

                function makeGrad() {
                    const ctx = canvas.getContext('2d');
                    const grad = ctx.createLinearGradient(0, 0, 0, canvas.parentElement.clientHeight || 300);
                    grad.addColorStop(0, 'oklch(0.6174 0.1381 160.7161 / 0.25)');
                    grad.addColorStop(1, 'oklch(0.6174 0.1381 160.7161 / 0)');
                    return grad;
                }

                const titleLabels = {
                    daily:    'Daily profit <span class="text-muted font-normal text-sm">(all-time)</span>',
                    overtime: 'Overtime profit <span class="text-muted font-normal text-sm">(all-time)</span>',
                };

                const STORAGE_KEY = 'allTimeChartMode';
                const savedMode = localStorage.getItem(STORAGE_KEY) || 'overtime';
                const initData = savedMode === 'overtime' ? overtimeValues : dailyValues;

                canvas._chartInstance = new Chart(canvas, {
                    type: 'line',
                    data: {
                        labels,
                        datasets: [{
                            data: initData,
                            borderColor: primaryColor,
                            borderWidth: 2,
                            tension: 0.4,
                            pointRadius: 0,
                            pointHoverRadius: 5,
                            pointHoverBackgroundColor: primaryColor,
                            pointHoverBorderColor: cardBgColor,
                            pointHoverBorderWidth: 2,
                            fill: true,
                            backgroundColor: makeGrad(),
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: { duration: 0 },
                        interaction: { mode: 'index', intersect: false },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: cardBgColor,
                                titleColor: mutedFgColor,
                                bodyColor: cs.getPropertyValue('--card-foreground').trim(),
                                padding: 10,
                                cornerRadius: 6,
                                callbacks: {
                                    title: (items) => labels[items[0]?.dataIndex] ?? '',
                                    label: (item)  => '  $' + Number(item.parsed.y).toFixed(2),
                                }
                            },
                        },
                        scales: {
                            x: { display: false },
                            y: {
                                grid: { color: borderColor },
                                border: { display: false },
                                ticks: {
                                    color: mutedFgColor,
                                    font: { size: 11 },
                                    callback: (v) => '$' + Number(v).toLocaleString('en-US', { maximumFractionDigits: 0 }),
                                },
                            },
                        },
                    }
                });

                canvas.style.animation = 'revealChart 2s cubic-bezier(0.16,1,0.3,1) forwards';

                // Apply saved mode to buttons + title on init
                const toggleGroup = document.getElementById('allTimeChartToggle');
                const titleEl = document.getElementById('allTimeChartTitle');
                function applyMode(mode) {
                    toggleGroup.querySelectorAll('button').forEach(b => {
                        const isActive = b.dataset.chartMode === mode;
                        b.style.background = isActive ? 'var(--card)' : 'transparent';
                        b.style.color      = isActive ? 'var(--foreground)' : 'var(--muted-foreground)';
                        b.style.boxShadow  = isActive ? 'var(--shadow-sm)' : 'none';
                    });
                    if (titleEl) titleEl.innerHTML = titleLabels[mode] || titleLabels.overtime;
                    const chart = canvas._chartInstance;
                    if (!chart) return;
                    chart.data.datasets[0].data = mode === 'overtime' ? overtimeValues : dailyValues;
                    chart.data.datasets[0].backgroundColor = makeGrad();
                    chart.update('none');
                }

                applyMode(savedMode);

                if (toggleGroup) {
                    toggleGroup.addEventListener('click', function (e) {
                        const btn = e.target.closest('[data-chart-mode]');
                        if (!btn) return;
                        const mode = btn.dataset.chartMode;
                        localStorage.setItem(STORAGE_KEY, mode);
                        applyMode(mode);
                    });
                }
            }, 50);
            </script>
        </div>
<% } %>
