<% const hasInstance = !!instance?.id; %>
<% const isRunning = !!botStatus?.isRunning; %>
<% const secretsConfigured = !!instance?.private_key; %>
<% const secretsReady = secretsConfigured || !!envSecretsConfigured; %>

<div class="flex flex-col md:flex-row flex-wrap items-stretch md:items-start justify-between gap-3">

    <!-- Account block: stacks first on mobile -->
    <div class="grow md:grow-0 order-1">
        <div class="flex flex-wrap gap-2 items-baseline mb-2">
            <span class="font-semibold">Account</span>
            <span class="text-muted mr-1">#<%= instance?.id ?? '-' %></span>
        </div>

        <div class="mt-2">
            <div class="flex items-center gap-2">
                <span class="text-muted" style="min-width: 4.5rem;">Name</span>
                <span><%= instance?.name ?? '-' %></span>
                <% if (hasInstance) { %>
                    <span class="badge <%= secretsReady ? 'text-bg-success' : 'text-bg-secondary' %>">
                        <%= secretsReady ? 'Configured' : 'Not configured' %>
                    </span>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Bot status -->
    <div class="grow md:grow-0 order-2">
        <div class="flex items-center gap-2">
            <span class="font-semibold">Bot status</span>
            <span class="badge <%= isRunning ? 'text-bg-success' : 'text-bg-secondary' %>">
                <%= isRunning ? 'Running' : 'Stopped' %>
            </span>
        </div>
        <p class="text-muted text-sm mt-1 mb-0">
            Controls the trading process for this instance.
        </p>
    </div>

    <!-- Actions -->
    <div class="flex flex-col gap-2 order-3 w-full md:w-auto items-stretch md:items-end" style="min-width: 100px;">
        <% if (hasInstance) { %>
            <% if (isRunning) { %>
                <form method="POST" action="/dashboard/instances/<%= instance.id %>/stop" class="m-0" style="min-width: 100px;">
                    <button type="submit" class="btn btn-outline-danger btn-sm w-full" style="min-width: 100px;" onclick="return confirm('Stop the bot for this instance?');">
                        Stop bot
                    </button>
                </form>
            <% } else { %>
                <form method="POST" action="/dashboard/instances/<%= instance.id %>/start" class="m-0" style="min-width: 100px;">
                    <button type="submit" class="btn btn-success btn-sm w-full" style="min-width: 100px;">
                        Start bot
                    </button>
                </form>
            <% } %>

            <div style="min-width: 100px;">
                <button
                    type="button"
                    class="btn btn-outline-secondary btn-sm w-full"
                    style="min-width: 100px;"
                    hx-get="/dashboard/instances/<%= instance.id %>/logs?lines=100"
                    hx-target="#pm2LogsBody"
                    hx-trigger="click"
                    data-bs-toggle="modal"
                    data-bs-target="#pm2LogsModal"
                >
                    Check logs
                </button>
            </div>
        <% } %>
    </div>

    <div class="modal fade" id="pm2LogsModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Bot Logs</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="pm2LogsBody">
                    <div class="text-muted text-sm">Loading…</div>
                </div>
            </div>
        </div>
    </div>

</div>
