<div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">

    <% const hasInstance = !!instance?.id; %>
    <% const isRunning = !!botStatus?.isRunning; %>
    <% const secretsConfigured = !!instance?.private_key; %>

    <!-- Left: Account -->
    <div class="me-auto position-relative" style="min-width: 260px; padding-right: 120px;">

        <% if (hasInstance) { %>
            <button
                    class="btn btn-outline-primary btn-sm position-absolute top-0 end-0"
                    data-bs-toggle="modal"
                    data-bs-target="#secretsModal"
            >
                Set secrets
            </button>
        <% } %>

        <div class="d-flex gap-2 align-items-baseline">
            <div class="fw-semibold">Account</div>
            <div class="text-muted">ID: <%= instance?.id ?? '-' %></div>
        </div>

        <div class="mt-3">
            <div class="d-flex">
                <div class="text-muted" style="width: 90px;">Name</div>
                <div><%= instance?.name ?? '-' %></div>
            </div>

            <div class="d-flex mt-1 align-items-center">
                <div class="text-muted" style="width: 90px;">Secrets</div>

                <% if (!hasInstance) { %>
                    <span class="text-muted">-</span>
                <% } else { %>
                    <span class="badge <%= secretsConfigured ? 'text-bg-success' : 'text-bg-secondary' %>">
            <%= secretsConfigured ? 'Configured' : 'Not configured' %>
          </span>
                    <% if (!secretsConfigured) { %>
                        <span class="text-muted small ms-2">Can also be provided via .env</span>
                    <% } %>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Middle: Bot status -->
    <div style="min-width: 320px;">
        <div class="d-flex align-items-center gap-2">
            <div class="fw-semibold">Bot status</div>
            <span class="badge <%= isRunning ? 'text-bg-success' : 'text-bg-secondary' %>">
        <%= isRunning ? 'Running' : 'Stopped' %>
      </span>
        </div>
        <div class="text-muted small mt-1">
            Controls the trading process for this instance.
        </div>
    </div>

    <!-- Right: Actions -->
    <div class="d-flex flex-column align-items-end gap-2" style="min-width: 180px;">

        <% if (hasInstance) { %>
            <% if (isRunning) { %>
                <form method="POST" action="/dashboard/instances/<%= instance.id %>/stop" class="m-0">
                    <button class="btn btn-outline-danger btn-sm" style="width: 100px;" onclick="return confirm('Stop the bot for this instance?');">
                        Stop bot
                    </button>
                </form>
            <% } else { %>
                <form method="POST" action="/dashboard/instances/<%= instance.id %>/start" class="m-0">
                    <button class="btn btn-success btn-sm" <%= secretsConfigured ? '' : 'disabled' %> title="<%= secretsConfigured ? '' : 'Configure secrets first' %>"  style="width: 100px;">
                        Start bot
                    </button>
                </form>
            <% } %>

            <button
                    class="btn btn-outline-secondary btn-sm"
                    style="width: 100px;"
                    hx-get="/dashboard/instances/<%= instance.id %>/logs?lines=100"
                    hx-target="#pm2LogsBody"
                    hx-trigger="click"
                    data-bs-toggle="modal"
                    data-bs-target="#pm2LogsModal"
            >
                Check logs
            </button>
        <% } %>
    </div>

    <div class="modal fade" id="pm2LogsModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Bot Logs</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="pm2LogsBody">
                    <div class="text-muted small">Loading…</div>
                </div>
            </div>
        </div>
    </div>

</div>