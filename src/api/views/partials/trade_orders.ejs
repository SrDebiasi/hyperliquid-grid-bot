<style>
.orders-table th { font-size: 0.75rem; font-weight: 600; color: #6c757d; text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--bs-border-color); }
.orders-table td { font-size: 0.85rem; vertical-align: middle; border-bottom: 1px solid var(--bs-border-color-translucent); }
.orders-table tbody tr { transition: background 0.1s; }
.orders-table tbody tr:hover { background: var(--bs-secondary-bg) !important; }
.orders-table tbody tr.row-buy  { border-left: 3px solid #198754; }
.orders-table tbody tr.row-sell { border-left: 3px solid #0d6efd; }
.order-id { font-family: monospace; font-size: 0.78rem; color: #6c757d; cursor: default; }
.th-buy  { background: #f0faf5; }
.th-sell { background: #f0f4ff; }
[data-bs-theme="dark"] .th-buy  { background: rgba(25, 135, 84, 0.12); }
[data-bs-theme="dark"] .th-sell { background: rgba(13, 110, 253, 0.12); }
</style>

<h2 class="h5 mb-3">Orders</h2>

<% if (!orders || orders.length === 0) { %>
    <div class="text-muted small">No orders found.</div>
<% } else { %>

    <%
        const num = (v) => { const n = Number(v); return Number.isFinite(n) ? n : null; };
        const hasBuy  = (o) => !!o.buy_order;
        const hasSell = (o) => !!o.sell_order;

        const buys = orders
            .filter(hasBuy)
            .map(o => ({ o, p: num(o.buy_price) }))
            .filter(x => x.p !== null)
            .sort((a, b) => b.p - a.p)
            .slice(0, 6).map(x => x.o);

        const sells = orders
            .filter(hasSell)
            .map(o => ({ o, p: num(o.sell_price) }))
            .filter(x => x.p !== null)
            .sort((a, b) => a.p - b.p)
            .slice(0, 6).map(x => x.o);

        const fmtPrice = (v) => {
            const n = Number(v);
            return Number.isFinite(n) ? n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 2 }) : '-';
        };

        const fmtUsd = (v) => {
            const n = Number(v);
            if (!Number.isFinite(n)) return '-';
            return n.toLocaleString('en-US', { style: 'currency', currency: 'USD' });
        };

        const usdFor = (qty, price) => {
            const q = num(qty), p = num(price);
            return (q === null || p === null) ? null : q * p;
        };

        const shortId = (id) => id ? String(id).slice(-8) : '-';

        const map = new Map();
        for (const o of [...buys, ...sells]) map.set(o.id, o);
        const displayOrders = Array.from(map.values()).sort((a, b) => {
            const ab = num(a.buy_price), bb = num(b.buy_price);
            if (ab !== null && bb !== null) return ab - bb;
            const as = num(a.sell_price), bs = num(b.sell_price);
            if (as !== null && bs !== null) return as - bs;
            return (a.id ?? 0) - (b.id ?? 0);
        });
    %>

    <!-- Legend + toggle -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex gap-3 small text-muted">
            <span class="d-flex align-items-center gap-1">
                <i class="bi bi-currency-dollar text-success"></i> Profit on next fill
            </span>
            <span class="d-flex align-items-center gap-1">
                <i class="bi bi-hourglass-split text-warning"></i> Waiting for cycle
            </span>
        </div>
        <button id="ordersToggleBtn" type="button" class="btn btn-outline-secondary btn-sm" data-state="filtered">
            Show all
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-sm orders-table mb-0">
            <thead>
                <tr>
                    <th class="text-center"></th>
                    <th class="th-buy text-end">Buy price</th>
                    <th class="th-buy text-center">Buy order</th>
                    <th class="th-buy text-end">Buy USD</th>
                    <th class="th-sell text-end">Sell price</th>
                    <th class="th-sell text-center">Sell order</th>
                    <th class="th-sell text-end">Sell USD</th>
                    <th class="text-end">Qty</th>
                    <th class="text-center">Last side</th>
                    <th class="text-end">Entry price</th>
                </tr>
            </thead>

            <tbody id="ordersTbodyFiltered">
            <% displayOrders.forEach((o) => {
                const buyUsd  = usdFor(o.quantity, o.buy_price);
                const sellUsd = usdFor(o.quantity, o.sell_price);
                const isBuy   = o.last_side === 'BUY';
            %>
            <tr class="<%= isBuy ? 'row-buy' : 'row-sell' %>">
                <td class="text-center" style="width:36px;">
                    <% if (o.last_operation) { %>
                        <i class="bi bi-currency-dollar text-success" title="Profit on next fill"></i>
                    <% } else { %>
                        <i class="bi bi-hourglass-split text-warning" title="Waiting for cycle"></i>
                    <% } %>
                </td>
                <td class="text-end fw-medium"><%= fmtPrice(o.buy_price) %></td>
                <td class="text-center">
                    <% if (o.buy_order) { %>
                        <span class="order-id" title="<%= o.buy_order %>"><%= shortId(o.buy_order) %></span>
                    <% } else { %>
                        <span class="text-muted">—</span>
                    <% } %>
                </td>
                <td class="text-end text-muted"><%= buyUsd === null ? '—' : fmtUsd(buyUsd) %></td>

                <td class="text-end fw-medium"><%= fmtPrice(o.sell_price) %></td>
                <td class="text-center">
                    <% if (o.sell_order) { %>
                        <span class="order-id" title="<%= o.sell_order %>"><%= shortId(o.sell_order) %></span>
                    <% } else { %>
                        <span class="text-muted">—</span>
                    <% } %>
                </td>
                <td class="text-end text-muted"><%= sellUsd === null ? '—' : fmtUsd(sellUsd) %></td>

                <td class="text-end text-muted"><%= o.quantity ?? '—' %></td>
                <td class="text-center">
                    <span class="badge <%= isBuy ? 'text-bg-success' : 'text-bg-primary' %>" style="font-size:0.7rem;">
                        <%= o.last_side ?? '—' %>
                    </span>
                </td>
                <td class="text-end text-muted"><%= fmtPrice(o.entry_price) %></td>
            </tr>
            <% }) %>
            </tbody>

            <tbody id="ordersTbodyAll" class="d-none">
            <% orders.forEach((o) => {
                const buyUsd  = usdFor(o.quantity, o.buy_price);
                const sellUsd = usdFor(o.quantity, o.sell_price);
                const isBuy   = o.last_side === 'BUY';
            %>
            <tr class="<%= isBuy ? 'row-buy' : 'row-sell' %>">
                <td class="text-center" style="width:36px;">
                    <% if (o.last_operation) { %>
                        <i class="bi bi-currency-dollar text-success" title="Profit on next fill"></i>
                    <% } else { %>
                        <i class="bi bi-hourglass-split text-warning" title="Waiting for cycle"></i>
                    <% } %>
                </td>
                <td class="text-end fw-medium"><%= fmtPrice(o.buy_price) %></td>
                <td class="text-center">
                    <% if (o.buy_order) { %>
                        <span class="order-id" title="<%= o.buy_order %>"><%= shortId(o.buy_order) %></span>
                    <% } else { %>
                        <span class="text-muted">—</span>
                    <% } %>
                </td>
                <td class="text-end text-muted"><%= buyUsd === null ? '—' : fmtUsd(buyUsd) %></td>

                <td class="text-end fw-medium"><%= fmtPrice(o.sell_price) %></td>
                <td class="text-center">
                    <% if (o.sell_order) { %>
                        <span class="order-id" title="<%= o.sell_order %>"><%= shortId(o.sell_order) %></span>
                    <% } else { %>
                        <span class="text-muted">—</span>
                    <% } %>
                </td>
                <td class="text-end text-muted"><%= sellUsd === null ? '—' : fmtUsd(sellUsd) %></td>

                <td class="text-end text-muted"><%= o.quantity ?? '—' %></td>
                <td class="text-center">
                    <span class="badge <%= isBuy ? 'text-bg-success' : 'text-bg-primary' %>" style="font-size:0.7rem;">
                        <%= o.last_side ?? '—' %>
                    </span>
                </td>
                <td class="text-end text-muted"><%= fmtPrice(o.entry_price) %></td>
            </tr>
            <% }) %>
            </tbody>
        </table>
    </div>

    <script>
    (function () {
        const btn        = document.getElementById('ordersToggleBtn');
        const tbFiltered = document.getElementById('ordersTbodyFiltered');
        const tbAll      = document.getElementById('ordersTbodyAll');
        if (!btn || !tbFiltered || !tbAll) return;

        btn.addEventListener('click', function () {
            const isFiltered = btn.getAttribute('data-state') === 'filtered';
            tbFiltered.classList.toggle('d-none',  isFiltered);
            tbAll.classList.toggle('d-none', !isFiltered);
            btn.setAttribute('data-state', isFiltered ? 'all' : 'filtered');
            btn.textContent = isFiltered ? 'Show around price' : 'Show all';
        });
    })();
    </script>

<% } %>
