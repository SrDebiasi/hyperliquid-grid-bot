<h2 class="text-xl font-semibold mb-3">Orders</h2>

<% if (!orders || orders.length === 0) { %>
    <div class="text-muted text-sm">No orders found.</div>
<% } else { %>

    <%
        const num = (v) => { const n = Number(v); return Number.isFinite(n) ? n : null; };
        const hasBuy  = (o) => !!o.buy_order;
        const hasSell = (o) => !!o.sell_order;

        const buys = orders
            .filter(hasBuy)
            .map(o => ({ o, p: num(o.buy_price) }))
            .filter(x => x.p !== null)
            .sort((a, b) => b.p - a.p)
            .slice(0, 6).map(x => x.o);

        const sells = orders
            .filter(hasSell)
            .map(o => ({ o, p: num(o.sell_price) }))
            .filter(x => x.p !== null)
            .sort((a, b) => a.p - b.p)
            .slice(0, 6).map(x => x.o);

        const fmtPrice = (v) => {
            const n = Number(v);
            return Number.isFinite(n) ? n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 2 }) : '-';
        };

        const fmtUsd = (v) => {
            const n = Number(v);
            if (!Number.isFinite(n)) return '-';
            return n.toLocaleString('en-US', { style: 'currency', currency: 'USD' });
        };

        const usdFor = (qty, price) => {
            const q = num(qty), p = num(price);
            return (q === null || p === null) ? null : q * p;
        };

        const shortId = (id) => id ? String(id).slice(-8) : '-';

        const map = new Map();
        for (const o of [...buys, ...sells]) map.set(o.id, o);
        const displayOrders = Array.from(map.values()).sort((a, b) => {
            const ab = num(a.buy_price), bb = num(b.buy_price);
            if (ab !== null && bb !== null) return ab - bb;
            const as = num(a.sell_price), bs = num(b.sell_price);
            if (as !== null && bs !== null) return as - bs;
            return (a.id ?? 0) - (b.id ?? 0);
        });
    %>

    <!-- Legend + toggle -->
    <div class="flex justify-between items-center mb-3">
        <div class="flex gap-3 text-sm text-muted">
            <span class="flex items-center gap-1">
                <i class="bi bi-currency-dollar text-success"></i> Profit on next fill
            </span>
            <span class="flex items-center gap-1">
                <i class="bi bi-hourglass-split text-warning"></i> Waiting for cycle
            </span>
        </div>
        <button id="ordersToggleBtn" type="button" class="btn btn-outline-secondary btn-sm" data-state="filtered">
            Show all
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-sm mb-0" style="font-size: 0.85rem;">
            <thead>
                <tr>
                    <th class="text-center" style="font-size: 0.75rem; font-weight: 600; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--border);"></th>
                    <th class="text-right" style="font-size: 0.75rem; font-weight: 600; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--border);">Buy price</th>
                    <th class="text-center" style="font-size: 0.75rem; font-weight: 600; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--border);">Buy order</th>
                    <th class="text-right" style="font-size: 0.75rem; font-weight: 600; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--border);">Buy USD</th>
                    <th class="text-right" style="font-size: 0.75rem; font-weight: 600; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--border);">Sell price</th>
                    <th class="text-center" style="font-size: 0.75rem; font-weight: 600; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--border);">Sell order</th>
                    <th class="text-right" style="font-size: 0.75rem; font-weight: 600; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--border);">Sell USD</th>
                    <th class="text-right" style="font-size: 0.75rem; font-weight: 600; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--border);">Qty</th>
                    <th class="text-center" style="font-size: 0.75rem; font-weight: 600; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--border);">Last side</th>
                    <th class="text-right" style="font-size: 0.75rem; font-weight: 600; color: var(--muted-foreground); text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 2px solid var(--border);">Entry price</th>
                </tr>
            </thead>

            <tbody id="ordersTbodyFiltered">
            <% displayOrders.forEach((o) => {
                const buyUsd  = usdFor(o.quantity, o.buy_price);
                const sellUsd = usdFor(o.quantity, o.sell_price);
                const isBuy   = o.last_side === 'BUY';
            %>
            <tr style="border-left: 3px solid <%= isBuy ? 'var(--primary)' : 'var(--chart-1)' %>; vertical-align: middle; border-bottom: 1px solid var(--border); transition: background 0.1s;" onmouseover="this.style.background='var(--muted)'" onmouseout="this.style.background=''">
                <td class="text-center" style="width:36px;">
                    <% if (o.last_operation) { %>
                        <i class="bi bi-currency-dollar text-success" title="Profit on next fill"></i>
                    <% } else { %>
                        <i class="bi bi-hourglass-split text-warning" title="Waiting for cycle"></i>
                    <% } %>
                </td>
                <td class="text-right font-medium"><%= fmtPrice(o.buy_price) %></td>
                <td class="text-center">
                    <% if (o.buy_order) { %>
                        <span style="font-family: monospace; font-size: 0.78rem; color: var(--muted-foreground); cursor: default;" title="<%= o.buy_order %>"><%= shortId(o.buy_order) %></span>
                    <% } else { %>
                        <span class="text-muted">—</span>
                    <% } %>
                </td>
                <td class="text-right text-muted"><%= buyUsd === null ? '—' : fmtUsd(buyUsd) %></td>

                <td class="text-right font-medium"><%= fmtPrice(o.sell_price) %></td>
                <td class="text-center">
                    <% if (o.sell_order) { %>
                        <span style="font-family: monospace; font-size: 0.78rem; color: var(--muted-foreground); cursor: default;" title="<%= o.sell_order %>"><%= shortId(o.sell_order) %></span>
                    <% } else { %>
                        <span class="text-muted">—</span>
                    <% } %>
                </td>
                <td class="text-right text-muted"><%= sellUsd === null ? '—' : fmtUsd(sellUsd) %></td>

                <td class="text-right text-muted"><%= o.quantity ?? '—' %></td>
                <td class="text-center">
                    <span class="badge <%= isBuy ? 'text-bg-success' : 'text-bg-primary' %>" style="font-size:0.7rem;">
                        <%= o.last_side ?? '—' %>
                    </span>
                </td>
                <td class="text-right text-muted"><%= fmtPrice(o.entry_price) %></td>
            </tr>
            <% }) %>
            </tbody>

            <tbody id="ordersTbodyAll" class="hidden">
            <% orders.forEach((o) => {
                const buyUsd  = usdFor(o.quantity, o.buy_price);
                const sellUsd = usdFor(o.quantity, o.sell_price);
                const isBuy   = o.last_side === 'BUY';
            %>
            <tr style="border-left: 3px solid <%= isBuy ? 'var(--primary)' : 'var(--chart-1)' %>; vertical-align: middle; border-bottom: 1px solid var(--border); transition: background 0.1s;" onmouseover="this.style.background='var(--muted)'" onmouseout="this.style.background=''">
                <td class="text-center" style="width:36px;">
                    <% if (o.last_operation) { %>
                        <i class="bi bi-currency-dollar text-success" title="Profit on next fill"></i>
                    <% } else { %>
                        <i class="bi bi-hourglass-split text-warning" title="Waiting for cycle"></i>
                    <% } %>
                </td>
                <td class="text-right font-medium"><%= fmtPrice(o.buy_price) %></td>
                <td class="text-center">
                    <% if (o.buy_order) { %>
                        <span style="font-family: monospace; font-size: 0.78rem; color: var(--muted-foreground); cursor: default;" title="<%= o.buy_order %>"><%= shortId(o.buy_order) %></span>
                    <% } else { %>
                        <span class="text-muted">—</span>
                    <% } %>
                </td>
                <td class="text-right text-muted"><%= buyUsd === null ? '—' : fmtUsd(buyUsd) %></td>

                <td class="text-right font-medium"><%= fmtPrice(o.sell_price) %></td>
                <td class="text-center">
                    <% if (o.sell_order) { %>
                        <span style="font-family: monospace; font-size: 0.78rem; color: var(--muted-foreground); cursor: default;" title="<%= o.sell_order %>"><%= shortId(o.sell_order) %></span>
                    <% } else { %>
                        <span class="text-muted">—</span>
                    <% } %>
                </td>
                <td class="text-right text-muted"><%= sellUsd === null ? '—' : fmtUsd(sellUsd) %></td>

                <td class="text-right text-muted"><%= o.quantity ?? '—' %></td>
                <td class="text-center">
                    <span class="badge <%= isBuy ? 'text-bg-success' : 'text-bg-primary' %>" style="font-size:0.7rem;">
                        <%= o.last_side ?? '—' %>
                    </span>
                </td>
                <td class="text-right text-muted"><%= fmtPrice(o.entry_price) %></td>
            </tr>
            <% }) %>
            </tbody>
        </table>
    </div>

    <script>
    (function () {
        const btn        = document.getElementById('ordersToggleBtn');
        const tbFiltered = document.getElementById('ordersTbodyFiltered');
        const tbAll      = document.getElementById('ordersTbodyAll');
        if (!btn || !tbFiltered || !tbAll) return;

        btn.addEventListener('click', function () {
            const isFiltered = btn.getAttribute('data-state') === 'filtered';
            tbFiltered.classList.toggle('hidden',  isFiltered);
            tbAll.classList.toggle('hidden', !isFiltered);
            btn.setAttribute('data-state', isFiltered ? 'all' : 'filtered');
            btn.textContent = isFiltered ? 'Show around price' : 'Show all';
        });
    })();
    </script>

<% } %>
