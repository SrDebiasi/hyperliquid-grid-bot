<%
const pageData = {
  configId: config?.id ?? null,
  pair: config?.pair ?? null,
};
%>

<script>
  window.__GRID_UI__ = <%- JSON.stringify(pageData) %>;
</script>

<div id="section-account" class="card shadow-sm">
  <div class="card-body">
    <%- include('../partials/trade_instance', { instance, botStatus, envSecretsConfigured }) %>
  </div>
</div>

<div id="section-config" class="card shadow-sm mt-3">
  <div class="card-body">
    <%- include('../partials/trade_config', { instance, config, orders }) %>
  </div>

  <%- include('../partials/modals/grid-simulate') %>
</div>


<div id="section-profits" class="card shadow-sm mt-3">
  <div class="card-body">
    <div
            hx-get="/dashboard/profits"
            hx-trigger="load, every 1m"
            hx-swap="innerHTML"
    >
      <%- include('../partials/profits.ejs', { profitSummary, portfolioOverview }) %>
    </div>
  </div>
</div>

<div id="section-orders" class="card shadow-sm mt-3">
  <div class="card-body">
    <%- include('../partials/trade_orders', { orders }) %>
  </div>
</div>

<div id="section-market" class="card shadow-sm mt-3">
  <div class="card-body">
      <%- include("../partials/market.ejs") %>
  </div>
</div>

<%- include('../partials/modals/secrets-modal', { instance, envWalletAddress, envPrivateKey }) %>
<%- include('../partials/modals/variables-modal', { instance, envTelegramBotToken, envTelegramChatId, envHealthchecksPingUrl, envHealthchecksPingIntervalMs, envBotTz, envHyperliquidTestnet }) %>
<%- include('../partials/modals/trade_config', { config }) %>

<script type="module" src="/js/market.js"></script>