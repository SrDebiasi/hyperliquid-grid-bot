<%
const pageData = {
  configId: config?.id ?? null,
  pair: config?.pair ?? null,
};
%>

<script>
  window.__GRID_UI__ = <%- JSON.stringify(pageData) %>;
</script>

<% if (instances && instances.length > 1) { %>
<div class="card shadow-sm mb-3">
  <div class="card-body py-2">
    <div class="d-flex align-items-center gap-2">
      <span class="text-muted small">Instance</span>
      <select class="form-select form-select-sm w-auto" onchange="window.location.href='/dashboard?instanceId='+this.value">
        <% instances.forEach(inst => { %>
        <option value="<%= inst.id %>" <%= inst.id === instance?.id ? 'selected' : '' %>>
          #<%= inst.id %> — <%= inst.name || inst.pair || ('Instance ' + inst.id) %>
        </option>
        <% }) %>
      </select>
    </div>
  </div>
</div>
<% } %>

<div id="section-account" class="card shadow-sm">
  <div class="card-body">
    <%- include('../partials/trade_instance', { instance, botStatus, envSecretsConfigured }) %>
  </div>
</div>

<div id="section-config" class="card shadow-sm mt-3">
  <div class="card-body">
    <%- include('../partials/grid_config', { instance, config, orders }) %>
  </div>

  <%- include('../partials/modals/grid-simulate') %>
</div>


<div id="section-profits" class="card shadow-sm mt-3">
  <div class="card-body">
    <div
            hx-get="/dashboard/profits?instanceId=<%= instance?.id ?? '' %>"
            hx-trigger="load, every 1m"
            hx-swap="innerHTML"
    >
      <%- include('../partials/profits.ejs', { profitSummary, portfolioOverview }) %>
    </div>
  </div>
</div>

<div id="section-orders" class="card shadow-sm mt-3">
  <div class="card-body" id="section-orders-body">
    <%- include('../partials/trade_orders', { orders }) %>
  </div>
</div>

<div id="section-market" class="card shadow-sm mt-3">
  <div class="card-body">
      <%- include("../partials/market.ejs") %>
  </div>
</div>

<%- include('../partials/modals/secrets-modal', { instance, envWalletAddress, envPrivateKey }) %>
<%- include('../partials/modals/variables-modal', { instance, envTelegramBotToken, envTelegramChatId, envHealthchecksPingUrl, envHealthchecksPingIntervalMs, envBotTz, envHyperliquidTestnet }) %>
<%- include('../partials/modals/config_modal', { config }) %>

<script type="module" src="/js/market.js"></script>

<script>
(function () {
    const instanceId = <%= instance?.id ?? 'null' %>;
    if (!instanceId) return;

    // ── Orders auto-refresh ───────────────────────────────────────────────
    const ordersBody = document.getElementById('section-orders-body');

    async function refreshOrders() {
        // Skip if manage-orders modal is open to avoid interfering
        if (document.getElementById('manageOrdersModal')?.classList.contains('show')) return;
        try {
            const res = await fetch(`/dashboard/orders?instanceId=${instanceId}`, { headers: { Accept: 'text/html' } });
            if (!res.ok) return;
            const html = await res.text();
            if (ordersBody) ordersBody.innerHTML = html;
        } catch (_) {}
    }

    setInterval(refreshOrders, 30_000);
})();
</script>