                <h5 class="modal-title" id="donateModalLabel">Donate</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-sm text-muted mb-3">Send crypto to support BotGrid.</p>

                <div class="mb-3">
                    <div class="font-semibold mb-1">Bitcoin (BTC)</div>
                    <div class="font-monospace text-sm text-break">bc1qz54alkzd3vtr9zgk3l76mqneecelvxsvtc9w27</div>
                    <button type="button" class="btn btn-outline-secondary btn-sm mt-2"
                            onclick="copyText('bc1qz54alkzd3vtr9zgk3l76mqneecelvxsvtc9w27')">
                        Copy BTC address
                    </button>
                </div>

                <div class="mb-3">
                    <div class="font-semibold mb-1">EVM (0x)</div>
                    <div class="font-monospace text-sm text-break">0x28A5577ff62F56A2Ea1Ed96c78c0015a88a66207</div>
                    <div class="flex flex-wrap gap-2 mt-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                onclick="copyText('0x28A5577ff62F56A2Ea1Ed96c78c0015a88a66207')">
                            Copy EVM address
                        </button>
                        <a class="btn btn-outline-success btn-sm"
                           href="https://metamask.app.link/send/0x28A5577ff62F56A2Ea1Ed96c78c0015a88a66207@1"
                           target="_blank" rel="noopener noreferrer">MetaMask (ETH)</a>
                        <a class="btn btn-outline-success btn-sm"
                           href="https://metamask.app.link/send/0x28A5577ff62F56A2Ea1Ed96c78c0015a88a66207@42161"
                           target="_blank" rel="noopener noreferrer">MetaMask (ARB)</a>
                        <a class="btn btn-outline-success btn-sm"
                           href="https://metamask.app.link/send/0x28A5577ff62F56A2Ea1Ed96c78c0015a88a66207@8453"
                           target="_blank" rel="noopener noreferrer">MetaMask (BASE)</a>
                    </div>
                    <p class="text-muted text-xs mt-2">Tip: pick the same network you're sending on (ETH / ARB / BASE).</p>
                </div>

                <div>
                    <div class="font-semibold mb-1">Solana (SOL)</div>
                    <div class="font-monospace text-sm text-break">BejrknxAdRp3KscAwpRUHVHG3sKUah6eSyPmFTJpwo1s</div>
                    <button type="button" class="btn btn-outline-secondary btn-sm mt-2"
                            onclick="copyText('BejrknxAdRp3KscAwpRUHVHG3sKUah6eSyPmFTJpwo1s')">
                        Copy SOL address
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const darkInput = document.getElementById('dark-toggle-input');

        function applyTheme(theme) {
            document.documentElement.setAttribute('data-bs-theme', theme);
            localStorage.setItem('theme', theme);
            if (darkInput) darkInput.checked = (theme === 'dark');
        }

        applyTheme(localStorage.getItem('theme') || 'light');

        if (darkInput) {
            darkInput.addEventListener('change', () => {
                applyTheme(darkInput.checked ? 'dark' : 'light');
            });
        }

        document.getElementById('dark-toggle').addEventListener('mouseenter', function() { this.style.opacity = '1'; });
        document.getElementById('dark-toggle').addEventListener('mouseleave', function() { this.style.opacity = '0.5'; });
    });

    // Live clock
    function updateClock() {
        const el = document.getElementById('sidebar-clock');
        if (el) el.textContent = new Date().toUTCString().replace(' GMT', ' UTC');
    }
    updateClock();
    setInterval(updateClock, 1000);

    // Scroll-spy
    const sectionIds = ['section-account', 'section-config', 'section-profits', 'section-orders', 'section-market'];

    function setActiveNav(id) {
        document.querySelectorAll('.sidebar-link').forEach(l => l.classList.remove('active'));
        const link = document.querySelector(`.sidebar-link[data-section="${id}"]`);
        if (link) link.classList.add('active');
    }

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) setActiveNav(entry.target.id);
        });
    }, { rootMargin: '-15% 0px -75% 0px' });

    sectionIds.forEach(id => {
        const el = document.getElementById(id);
        if (el) observer.observe(el);
    });

    document.querySelectorAll('.sidebar-link').forEach(link => {
        link.addEventListener('click', e => {
            e.preventDefault();
            const el = document.getElementById(link.dataset.section);
            if (el) {
                el.scrollIntoView({ behavior: 'smooth', block: 'start' });
                setActiveNav(link.dataset.section);
            }
        });
    });

    // Mobile sidebar toggle
    (function() {
        const toggle = document.getElementById('sidebar-toggle');
        const backdrop = document.getElementById('sidebar-backdrop');
        const sidebar = document.querySelector('.app-sidebar');

        function openSidebar() {
            sidebar.classList.remove('-translate-x-full');
            backdrop.classList.remove('hidden');
        }
        function closeSidebar() {
            sidebar.classList.add('-translate-x-full');
            backdrop.classList.add('hidden');
        }

        toggle?.addEventListener('click', openSidebar);
        backdrop?.addEventListener('click', closeSidebar);

        document.querySelectorAll('.sidebar-link').forEach(link => {
            link.addEventListener('click', () => {
                if (window.innerWidth < 768) closeSidebar();
            });
        });
    })();

    // Tooltips
    function initTooltips(root = document) {
        root.querySelectorAll('[data-bs-toggle="tooltip"]').forEach((el) => {
            if (el._bsTooltip) return;
            el._bsTooltip = new bootstrap.Tooltip(el);
        });
    }
    document.addEventListener('DOMContentLoaded', () => initTooltips());
    document.body.addEventListener('htmx:afterSwap', (e) => { initTooltips(e.target); });
    document.body.addEventListener('shown.bs.modal', (e) => { initTooltips(e.target); });
</script>
<script src="/js/grid-ui.js"></script>
<script src="/js/trade-order.js"></script>
</body>
</html>
