            </div>
            <div class="modal-body">
                <div class="small text-muted mb-3">Send crypto to support BotGrid.</div>

                <!-- BTC -->
                <div class="mb-3">
                    <div class="fw-semibold">Bitcoin (BTC)</div>
                    <div class="font-monospace small text-break">bc1qz54alkzd3vtr9zgk3l76mqneecelvxsvtc9w27</div>
                    <button type="button" class="btn btn-outline-secondary btn-sm mt-2"
                            onclick="copyText('bc1qz54alkzd3vtr9zgk3l76mqneecelvxsvtc9w27')">
                        Copy BTC address
                    </button>
                </div>

                <!-- EVM -->
                <div class="mb-3">
                    <div class="fw-semibold">EVM (0x)</div>
                    <div class="font-monospace small text-break">0x28A5577ff62F56A2Ea1Ed96c78c0015a88a66207</div>
                    <div class="d-flex flex-wrap gap-2 mt-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                onclick="copyText('0x28A5577ff62F56A2Ea1Ed96c78c0015a88a66207')">
                            Copy EVM address
                        </button>
                        <a class="btn btn-outline-success btn-sm"
                           href="https://metamask.app.link/send/0x28A5577ff62F56A2Ea1Ed96c78c0015a88a66207@1"
                           target="_blank" rel="noopener noreferrer">MetaMask (ETH)</a>
                        <a class="btn btn-outline-success btn-sm"
                           href="https://metamask.app.link/send/0x28A5577ff62F56A2Ea1Ed96c78c0015a88a66207@42161"
                           target="_blank" rel="noopener noreferrer">MetaMask (ARB)</a>
                        <a class="btn btn-outline-success btn-sm"
                           href="https://metamask.app.link/send/0x28A5577ff62F56A2Ea1Ed96c78c0015a88a66207@8453"
                           target="_blank" rel="noopener noreferrer">MetaMask (BASE)</a>
