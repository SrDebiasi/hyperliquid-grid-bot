                    <div class="text-muted small mt-2">Tip: pick the same network you're sending on (ETH / ARB / BASE).</div>
                </div>

                <!-- Solana -->
                <div>
                    <div class="fw-semibold">Solana (SOL)</div>
                    <div class="font-monospace small text-break">BejrknxAdRp3KscAwpRUHVHG3sKUah6eSyPmFTJpwo1s</div>
                    <button type="button" class="btn btn-outline-secondary btn-sm mt-2"
                            onclick="copyText('BejrknxAdRp3KscAwpRUHVHG3sKUah6eSyPmFTJpwo1s')">
                        Copy SOL address
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>
